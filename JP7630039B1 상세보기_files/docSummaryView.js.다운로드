/**
 * 상세보기 문헌전체 탭
 * @returns
 */
var DocCmmVO = {};

;(function($){
	
	//=================================
	// [S] Related Application
	//=================================
	var RelApplPageVO = {};
	RelApplPageVO.id = 'devRelAppl';
	RelApplPageVO.item = 'RelAppl';
	RelApplPageVO.pageRow = 10;
	RelApplPageVO.prntId = 'devRelAppl';
	RelApplPageVO.chldId = 'RelAppl';
	RelApplPageVO.prntPageRow = 20;
	RelApplPageVO.chldPageRow = 10;
	
	$.getRelApplList = function(pageNum, type){
		//미국은 구조 다름
		if($("#ctry").val() == "US"){
			$.getRelApplUsList(pageNum, type)
		} else {
			var url = "";
			if($("#ctry").val() == "AU"){
				url = '../dau/findRelatedApplication.wips';
			}
			var data = {
					"skey" : $("#skey").val()
					, "type" : RelApplPageVO.type
				}
			
			// 최초 진입 시
			if(RelApplPageVO.pageNum == undefined || RelApplPageVO.pageNum == 0 || pageNum == undefined || pageNum == 0){
				RelApplPageVO.pageNum = 1;
			} else {
				RelApplPageVO.pageNum = pageNum;
			}
			
			data.pageNum = parseInt(RelApplPageVO.pageNum);
			data.rowCount = parseInt(RelApplPageVO.pageRow);
			
			$.ajax({
				url            : url,
				type         : 'POST',
				cache       : false,
				async       : true,
				dataType  : 'json',
				data        : data ,
				success     : function(data, textStatus, jqXHR) {
					
					// 최초 진입 시 PAGING COUNT SET
					RelApplPageVO.totCnt = data.totalRow + data.provisionalList.length + data.missingList.length;
					RelApplPageVO.totPageCnt = Math.floor(data.totalRow / RelApplPageVO.pageRow) + (data.totalRow % RelApplPageVO.pageRow == 0 ? 0 : 1) ;
					RelApplPageVO.skeys = data.skeys;
					RelApplPageVO.prvTotCnt = data.provisionalList.length;
					RelApplPageVO.addTotCnt = data.addTotCnt;
					RelApplPageVO.divTotCnt = data.divTotCnt;
					
					if(RelApplPageVO.totPageCnt == 0) {RelApplPageVO.totPageCnt = 1;}
					
					if(RelApplPageVO.totCnt > 0){
						if(!$("#"+RelApplPageVO.id).is(':parent')){
							var theadData = {
									id: 'devRelAppl'
									, item: 'RelAppl'
									, scrollId : 'devRA'
									, ezvChk: false
									, myfolderChk: false
									, copChk: false
									, allChk: false
									, pageChk: true
									, missChk: true
									, tpCntChk: true
									, thead:[
												 {nm:'No', sortField:'', size:'30'}
									       		, {nm:'원문', sortField:'', size:'40'}
									       		, {nm:'관계', sortField:'', size:'120'}
									       		, {nm:'출원번호', sortField:'', size:'120'}
									       		, {nm:'출원일자', sortField:'', size:'90'}
									       		, {nm:'문헌번호', sortField:'', size:'120'}
									       		, {nm:'발명의 명칭', sortField:'', size:'*'}
									       	]
							};
							
							$("#devRelAppl").append($("#tmplViewTableInfo").render({title:"관련출원", data:theadData}));
							// 상세보기 오른쪽 메뉴 레이어 메뉴 수정
							scrollRightSet("devRA", "Related Appl.");
						}
						
						// 데이터 출력 함수 호출
						$.fnRelApplListSuccess(data);
						
					} else {
						$("#"+RelApplPageVO.id).remove();
					}
				},
				error   : function(jqXHR, textStatus, errorThrown) {
				}
			});
		}
	}
	
	$.fnRelApplListSuccess = function(data){
		// 공통 객체에 PAGE 객체 저장
		DocCmmVO.RelAppl = RelApplPageVO;
		
		// SETTING
		$("#"+RelApplPageVO.id+"Cnt").text(RelApplPageVO.totCnt);
		$("#maxSkey_"+RelApplPageVO.id).val(RelApplPageVO.skeys);
		$("#devAddCnt").text("("+RelApplPageVO.addTotCnt+")");
		$("#devDivCnt").text("("+RelApplPageVO.divTotCnt+")");
		$("#devPrvCnt").text("("+RelApplPageVO.prvTotCnt+")");
		
		// PAGING
		$("#"+RelApplPageVO.id+"Page").empty();
		$("#"+RelApplPageVO.id+"Page").html($("#tmplViewTablePage").render({pageNum:RelApplPageVO.pageNum, totPageCnt:RelApplPageVO.totPageCnt, type:'', item:RelApplPageVO.item}));
		
		// DATA LIST
		$("#"+RelApplPageVO.id+"List").empty();
		if(data.relApplTextList.length > 0){
			var idx = (RelApplPageVO.pageNum - 1 ) * RelApplPageVO.pageRow;
			$("#"+RelApplPageVO.id+"List").html($("#tmplRelApplDataTableList").render({data:data.relApplTextList, idx:idx, chldIdx:0}));
		} else {
			$("#"+RelApplPageVO.id+"List").html("<tr><td colspan='7' class='font_align_center'>해당 정보가 없습니다.</td></tr>");
		}
		// ETC DATA List
		if(data.missingList.length > 0 || data.provisionalList.length > 0){
			if($("#"+RelApplPageVO.id+"EtcList:not(:has(p))")){
				$("#"+RelApplPageVO.id+"EtcList").empty();
				$("#"+RelApplPageVO.id+"EtcList").html($("#tmplEtcViewTable").render({missList:data.missingList, provList:data.provisionalList}));
			}
		}
		
	}
	
	//US용
	$.getRelApplUsList = function(pageNum, type){
		
		// 데이터 조회 타입 선언 (all:전체, prnt:부모, chld:자식)
		if(RelApplPageVO.type == undefined || RelApplPageVO.type == null || type == undefined || type == null){
			RelApplPageVO.type = "all";
		} else {
			RelApplPageVO.type = type;
		}
		
		var data = {
				"skey" : $("#skey").val()
				, "type" : RelApplPageVO.type
			}
		
		// 부모출원 페이징 or 최초 진입 시
		if(RelApplPageVO.type == "prnt" || RelApplPageVO.type == "all"){
			if(RelApplPageVO.prntPageNum == undefined || RelApplPageVO.prntPageNum == 0 || pageNum == undefined || pageNum == 0){
				RelApplPageVO.prntPageNum = 1;
			} else {
				RelApplPageVO.prntPageNum = pageNum;
			}
			
			data.pageNum = parseInt(RelApplPageVO.prntPageNum);
			data.rowCount = parseInt(RelApplPageVO.prntPageRow);
		}
		// 자식출원 페이징 or 최초 진입 시
		if(RelApplPageVO.type == "chld" || RelApplPageVO.type == "all") {
			if(RelApplPageVO.chldPageNum == undefined || RelApplPageVO.chldPageNum == 0 || pageNum == undefined || pageNum == 0){
				RelApplPageVO.chldPageNum = 1;
			} else {
				RelApplPageVO.chldPageNum = pageNum;
			}
			
			data.pageNum = parseInt(RelApplPageVO.chldPageNum);
			data.rowCount = parseInt(RelApplPageVO.chldPageRow);
		}
		
		$.ajax({
			url            : '../dus/findRelatedApplication.wips',
			type         : 'POST',
			cache       : false,
			async       : true,
			dataType  : 'json',
			data        : data ,
			success     : function(data, textStatus, jqXHR) {
				
				// 최초 진입 시 PAGING COUNT SET
				if(RelApplPageVO.type == "all"){
					RelApplPageVO.prntCnt = data.relApplCnt.prntTotCnt == null ? 0 : data.relApplCnt.prntTotCnt;
					RelApplPageVO.prntTotCnt = data.relApplCnt.prntTotCnt + data.missingList.length + data.provisionalList.length;
					RelApplPageVO.chldTotCnt = data.relApplCnt.chldTotCnt == null ? 0 : data.relApplCnt.chldTotCnt;
					RelApplPageVO.totRsltCnt = RelApplPageVO.prntTotCnt + RelApplPageVO.chldTotCnt;
					RelApplPageVO.totPrntPageCnt = Math.floor(RelApplPageVO.prntCnt / RelApplPageVO.prntPageRow) + (RelApplPageVO.prntCnt % RelApplPageVO.prntPageRow == 0 ? 0 : 1) ;
					RelApplPageVO.totChldPageCnt = Math.floor(RelApplPageVO.chldTotCnt / RelApplPageVO.chldPageRow) + (RelApplPageVO.chldTotCnt % RelApplPageVO.chldPageRow == 0 ? 0 : 1) ;
					
					RelApplPageVO.skeys = data.skeys;
				}
				// 부모출원은 항상 표시해야해서 데이터 없을땐 0
				if(RelApplPageVO.totPrntPageCnt == 0){
					RelApplPageVO.prntPageNum = 0;
				}
				
				if(RelApplPageVO.totRsltCnt > 0){
					if(!$("#"+RelApplPageVO.id).is(':parent')){
						//부모출원 RA : RA 항목에서 항상 표시
						var theadData = {
								id: 'devRelAppl'
								, item: 'RelAppl'
								, analysis: 'RA'
								, scrollId : 'devRA'
								, ezvChk: false
								, myfolderChk: false
								, copChk: false
								, allChk: false
								, pageChk: true
								, missChk: true
								, tpCntChk: false
								, chldChk: (RelApplPageVO.chldTotCnt > 0 ? true : false)
								, thead:[
											{nm:'No', sortField:'', size:'30'}
											,{nm:'원문', sortField:'', size:'50'}
								       		, {nm:'유형', sortField:'', size:'70'}
								       		, {nm:'출원번호', sortField:'', size:'130'}
								       		, {nm:'출원일자', sortField:'', size:'130'}
								       		, {nm:'문헌번호', sortField:'', size:'130'}
								       		, {nm:'발명의 명칭', sortField:'', size:'*'}
								       	]
						};
						
						$("#devRelAppl").append($("#tmplRelApplUsViewTable").render({title:"관련출원", data:theadData}));
						// 상세보기 오른쪽 메뉴 레이어 메뉴 수정
						scrollRightSet("devRA", "Related Appl.");
					}
					
					// 데이터 출력 함수 호출
					$.fnRelApplUsListSuccess(data, "prnt");
					
					//자식출원 RA : 데이터 없을 때 표시 안함
					if(RelApplPageVO.chldTotCnt > 0){
						// 데이터 출력 함수 호출
						$.fnRelApplUsListSuccess(data, "chld");
					}
					
				} else {
					$("#"+RelApplPageVO.id).remove();
				}
			},
			error   : function(jqXHR, textStatus, errorThrown) {
			}
		});
	}


