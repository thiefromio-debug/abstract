function openFmlyClsLayer(skey, dbNm, ctry, clsType, clsIndex) {
	if($('#'+clsType+'_main'+'_lyr_'+clsIndex+'_0').css("display") == "none"){	//레이어는 만들어 졌으나 hide인 상태
		layerHide();
		$('#'+clsType+'_main'+'_lyr_'+clsIndex+'_0').show();
		$('#'+clsType+'_main'+'_div_'+clsIndex+'_0').attr("style", "position:relative;");
	} else if($('#'+clsType+'_main'+'_lyr_'+clsIndex+'_0').css("display") == "block"){	//레이터 열린 상태에서 다시 +버튼 누를때 닫기
		closeClsLayer(clsType , 'main'  , clsIndex , '0') ;
	} else {	// 레이어가 안만들어 졌을 때 ajax
		var url = "../doc/docFmlyCls.wips";
		var obj = { skey : skey, dbNm : dbNm, ctry : ctry, clsType:clsType};
		
		$.ajax({
			url			: url,
			type		: 'POST',
			cache		: false,
			async		: false,
			dataType	: 'json',
			data		: obj,
			success     : function(data, textStatus, jqXHR) {
				layerHide();
				if(clsType === 'ipc'){
					$('#'+clsType+'_main'+'_div_'+clsIndex+'_0 > div').append($("#tmplFmlyClsLayer").render({clsType:clsType, clsIndex:clsIndex, clsList:data.clsList}));
				} else if(clsType === 'cpc'){
					$('#'+clsType+'_main'+'_div_'+clsIndex+'_0 > div').append($("#tmplFmlyClsLayer").render({clsType:clsType, clsIndex:clsIndex, clsList:data.clsList}));
				}
				$('#'+clsType+'_main'+'_lyr_'+clsIndex+'_0').show();
				$('#'+clsType+'_main'+'_div_'+clsIndex+'_0').attr("style", "position:relative;");
			},
			error   : function(jqXHR, textStatus, errorThrown) {
			}
		});
	}
	
};

function layerHide() {
	var clsKinds = ["cpc", "ipc", "upc", "fi" , "fterm","locarno"];
	for (var i = 0; i < clsKinds.length; i++) {
		$( "div[id^="+clsKinds[i]+"_curr_lyr_]").hide();
		$( "div[id^="+clsKinds[i]+"_curr_div_]").attr("style", "");
		
		$( "div[id^="+clsKinds[i]+"_orig_lyr_]").hide();
		$( "div[id^="+clsKinds[i]+"_orig_div_]").attr("style", "");
		
		//wips 패밀리 IPC/CPC
		$( "div[id^="+clsKinds[i]+"_main_lyr_]").hide();
		$( "div[id^="+clsKinds[i]+"_main_div_]").attr("style", "");
	}
};

function closeClsLayer(clsType , clsStatus  , clsIndex , clsMode) {
	$('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).hide();
	$('#'+clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode).attr("style", "");
};
