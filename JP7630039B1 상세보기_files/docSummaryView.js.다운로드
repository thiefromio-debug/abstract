function groupByProperty(targetObjList, property) {
	// 객체를 그룹화할 때 사용할 객체
	var groupedObjects = {};
	
	// 객체 배열을 순회하면서 그룹화
	$.each(targetObjList, function(index, obj) {
		var propertyValues = (obj[property] || '').split(',').map(item => item.trim()); //콤마로 구분된 값을 배열로 분리
		if (propertyValues.length > 0 && propertyValues[0] !== '') {
			$.each(propertyValues, function(index, propertyName) {
				if (propertyName in groupedObjects) {
					groupedObjects[propertyName].cnt++; // 이미 있는 속성인 경우 개수 증가
				} else {
					groupedObjects[propertyName] = { tp: propertyName, cnt: 1 }; // 새로운 속성인 경우 객체 생성
				}
			});
		}
	});
	
	// 결과 리스트 생성
	var resultList = [];
	$.each(groupedObjects, function(propertyName, groupedObject) {
		resultList.push(groupedObject);
	});
	
	return resultList
}


//원하는 유형기준으로 건수 셋팅
function combineTypes(arr, baseType, otherType) {
	if (!arr || arr.length === 0) return [];
	
	var combined = [];
	let sum = 0;
	
	arr.forEach(function(item){
		if(item.tp === baseType){
			combined.push(item);
		} else {
			sum += item.cnt
		}
	});
	
	combined.push({tp:otherType, cnt:sum});
	
	return combined;
}
