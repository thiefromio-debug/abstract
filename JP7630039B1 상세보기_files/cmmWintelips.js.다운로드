	/**
	 * Smart quote(“, ‘)를 Straight quote(", ')로 변경합니다.
	 */
	$.convertSmartQuoteToStraightQuote = function(value) {
		value = value.replace( /\u2018|\u2019|\u201A|\uFFFD/g, "'" );
	    value = value.replace( /\u201c|\u201d|\u201e/g, '"' );
	    
	    return value;
	};
	
	/**
	 * Full width character를 일반 width character로 변경합니다.
	 */
	$.convertFullWidthCharacter = function(value) {
		value = value.replace(/＂/g, '"');
		value = value.replace(/＇ /g, "'");
		
		return value;
	};

	/**
	 * Zero width character를 일반 공백으로 변경합니다.
	 */
	$.convertZeroWidthCharacter = function(value) {
		value = value.replace(/​/g, ' ');
		
		return value;
	};
