function fnSessionStorageObjSet(gkey, key, val){
	try {
		var tmp = JSON.parse(sessionStorage.getItem(gkey));
		if(tmp == null){tmp = {};}
		
		// sessionStorage 입력 데이터 초과시 입력된순서대로 삭제 처리
		var size = fnSessionStorageSize(val.length);
		if(size > 4800000){
			var dataSize = 0;
			$.each(tmp, function(key, dataVal){
				tmp[key] = null;
				delete tmp[key];
				dataSize = dataSize + dataVal.length;
				if(dataSize >= val.length){
					return false;
				}
			});
		}
		
		tmp[key] = val;
		sessionStorage.setItem(gkey, JSON.stringify(tmp));
		tmp = null;
	} catch (e) {
		console.log("fnSessionStorageObjSet err");
	}
}

//Session Storage Size
function fnSessionStorageSize(dataSize){
	var size = 0;
	var key = "";
	for(var i=0 ; i  <  sessionStorage.length ; i++){
		key = sessionStorage.key(i);
		size = size + sessionStorage.getItem(key).length;
	}
	var key = null;
	
	//console.log("fnSessionStorageSize =" + size);
	return size+dataSize;
}

