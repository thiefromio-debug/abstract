//UserManual list 
$.createUserManualListHtml = function(data) {
	$("#devQuickManualList").empty();
	
	userManualList = data.ctsManualResultVO.manuList;
	userManualListCnt = data.ctsManualResultVO.totalCountForpaging;
	
	var pgnum 		= $("#devQuickManuPgnum").val(),
		insertBlock2 = new Array(),
		keyword = data.ctsManualParamVO.keyword;
			
	userManualList.forEach(function(item) {
		insertBlock2.push("<tr>");
		insertBlock2.push(" <td class='font_color_4c font_align_center'><span>" + (userManualListCnt - item.rowNumber + 1) + "</span></td>");
		insertBlock2.push(" <td class='txt_left highlightText'>");
		insertBlock2.push("  <p class='padd_left_05'>");
		insertBlock2.push("   <a href='../cts/userGuideManual.wips?type="+item.mtype+"&target="+item.brdid+"&keyword="+keyword+"' class='font_color_4c' target='_blank'> <span>" + item.ti + "</span></a>");
		insertBlock2.push("   <span class='font_color_4c cut_word'>" + item.cntnt + "</span>"); 
		insertBlock2.push("  </p>");
		insertBlock2.push(" </td>");
		insertBlock2.push("</tr>");
	})
		
	if(userManualList.length == 0){
		insertBlock2.push('<tr><td colspan="2"><p class="txt_nolist">! 검색결과가 존재하지 않습니다.</p></td></tr>');
	}
	
	$("#devQuickManualList").append(insertBlock2.join('\n'));
	
	$.createUserManualPagingHtml(data);
			
};
$.createUserManualPagingHtml = function(data) {

	var totCnt 	= data.ctsManualResultVO.totalCountForpaging,
		totPage = Math.ceil((totCnt - 5) / 5) + 1,
		pgnum   = $("#devQuickManuPgnum").val(),
		curPage = Math.ceil((pgnum) / 10),
		lastPgNum = (curPage * 10 < totPage)? curPage*10: totPage;

	$("#devQuickManualPaging").empty();
	var insertBlock = new Array();
	
//	console.log("totCnt:"+totCnt+"|totPage:"+totPage+"|pgnum:"+pgnum+"|curPage:"+curPage+"|lastPgNum:"+lastPgNum)
	
	insertBlock.push("<ul>");
	if(pgnum == 1) { //처음으로
		insertBlock.push("<a href='javascript:void(0);' class=' paging prev p1 btn_dis_type'>First pages</a>");
	} else {
		insertBlock.push("<a href='javascript:$.goQuickManuPage(1);' class=' paging prev p1'>First pages</a>");
	} 
	
	if (curPage == 1) {	//이전으로
		insertBlock.push("<a href='javascript:void(0);' class='paging prev p10 btn_dis_type'>Previous 10 page</a>");
	} else {
		insertBlock.push("<a href='javascript:$.goQuickManuPage(\"prev\");' class='paging prev p10'>Previous 10 page</a>");
	}
	
	for (i = ((curPage - 1) * 10) + 1; i <= lastPgNum; i++) { //1~10
		var lastClass = "";
		if (i == lastPgNum) {
			lastClass = "last";
		}
		if (pgnum == i) {
			insertBlock.push("<li class='on'><a href='javascript:void(0);'>" + i + "</a></li>");
		} else {
			insertBlock.push("<li><a href='javascript:$.goQuickManuPage(" + i + ");'>" + i + "</a></li>");
		}
		
	}
	if(lastPgNum == totPage) { //다음으로
		insertBlock.push("<a href='javascript:void(0);' class='next p1 btn_dis_type'>Next 10 pages</a>");
	} else {
		insertBlock.push("<a href='javascript:$.goQuickManuPage(\"next\");' class='next p1'>Next 10 pages</a>");
	}
	
	if(pgnum == totPage) {	//마지막으로
		insertBlock.push("<a href='javascript:void(0);' class='next p10 btn_dis_type'>Last page</a>");
	} else {
		insertBlock.push("<a href='javascript:$.goQuickManuPage(\"last\"," + totPage + ")' class='next p10'>Last page</a>");
	}
	insertBlock.push("</ul>");
	
	$("#devQuickManualPaging").append(insertBlock.join('\n'));
}
//UserManual paging 
$.goQuickManuPage = function(pgnum, totPage) {
	curPgnum = Number($("#devQuickManuPgnum").val());
	if (pgnum == 'prev') {
		$("#devQuickManuPgnum").val((Math.ceil(curPgnum/10)-1)*10);
	} else if (pgnum == 'next') {
		$("#devQuickManuPgnum").val(Math.ceil(curPgnum/10)*10+1);
	} else if (pgnum == 'last') {
		$("#devQuickManuPgnum").val(totPage);
	} else {
		$("#devQuickManuPgnum").val(pgnum);
	}
	$.selectUserManual();
};

// faq 조회
$.selectFaq = function() {
	
	var brdSectCd = $("li[id^='devCtgrClass'][class='on']").attr("id").replace('devCtgrClass', '') + '%',
		srchText = $("#devQuickSrchTxt").val(),
		pgnum = $("#devQuickPgnum").val(),
		pgrow = 5;
		
	if (pgnum != 1) {
		pgrow = pgnum * 10; 
		pgnum = 1;
	}
	
	$.fn.showHistoryLoadingbar('devQuickFaqLoadingbar');
	
	$.ajax({
		url: "../lyr/selectFaq.wips",
		type: 'POST',
		cache: false,
		async: true,
		dataType: 'json',
		global: false, 
		data: {
			brdSectCd : brdSectCd,
			srchText : srchText,
			pgnum: pgnum,
			pgrow: pgrow
		},
		success: function(data, textStatus, jqXHR) {
			$.createFaqListHtml(data);
			$.fn.hideHistoryLoadingbar('devQuickFaqLoadingbar');
		}
	});
	
};

// faq list 
$.createFaqListHtml = function(data) {
	$("#devQuickFaqTopList").empty();
	$("#devQuickFaqList").empty();
	
	faqTopList = data.topList;
	faqList = data.brdList.manuList;
	faqListCnt = data.brdList.totalCountForpaging;
	
	var insertBlock = new Array(),
		pgnum 		= $("#devQuickPgnum").val();
	
	for(var i=0 ; i < faqTopList.length ; i++){
		insertBlock.push("<li><a href=javascript:$.goFaqCntnt(" + faqTopList[i].brdId + ",'')>" + faqTopList[i].ti + "</a></li>");
	}
	if(faqTopList.length == 0 || pgnum != 1) {
		$("#devQuickFaqTopList").hide();
	} else {
		$("#devQuickFaqTopList").show();
	}
	
	var insertBlock2 = new Array(),
		startVal     = (pgnum == 1) ? 0 : (pgnum - 2) * 10 + 5,
		endVal       = (faqList.length > (pgnum * 10 - 5)) ? (pgnum * 10 - 5) : faqList.length;
	
	for(var i=startVal; i<endVal ; i++){
		insertBlock2.push("<li>");
		insertBlock2.push("<span>" + (faqListCnt - faqList[i].rowNumber + 1) + ".</span>");
		insertBlock2.push("<a href='javascript:$.goFaqCntnt(" + faqList[i].brdid + "," + faqList[i].rowNumber + ")'>" + faqList[i].ti + "</a>");
		insertBlock2.push("</li>");
	}
	if(faqList.length == 0){
		insertBlock2.push('<li class="no_data">작성된 게시물이 없습니다.</li>');
	}
	
	$("#devQuickFaqTopList").append(insertBlock.join('\n'));
	$("#devQuickFaqList").append(insertBlock2.join('\n'));
	
	$.createFaqPagingHtml(faqListCnt);
	
};

// faq paging
$.createFaqPagingHtml = function(data) {
	var totCnt 	= data,
		totPage = Math.ceil((totCnt - 5) / 10) + 1,
		pgnum   = $("#devQuickPgnum").val(),
		curPage = Math.ceil((pgnum) / 10),
		lastPgNum = (curPage * 10 < totPage)? curPage*10: totPage;
 
	$("#devQuickPaging").empty();
	var insertBlock = new Array();
	
	if(pgnum == 1) {
		insertBlock.push('<span class="btn_pagenate btn_first_quick btn_dis_type"><span class="screen_out">처음</span></span>');
	} else {
		insertBlock.push('<a href="javascript:$.goQuickPage(1)" class="btn_pagenate btn_first_quick"><span class="screen_out">처음</span></a>');
	} 
	
	if (curPage == 1) {
		insertBlock.push('<span class="btn_pagenate btn_before_quick btn_dis_type"><span class="screen_out">이전</span></span>');
	} else {
		insertBlock.push('<a href="javascript:$.goQuickPage(\'prev\')" class="btn_pagenate btn_before_quick"><span class="screen_out">이전</span></a>');
	}
	
	for (i = ((curPage - 1) * 10) + 1; i <= lastPgNum; i++) {
		var lastClass = '';
		if (i == lastPgNum) {
			lastClass = 'last';
		}
		if (pgnum == i) {
			insertBlock.push('<span class="pagenate_txt on '+ lastClass +'">'+ i + '</span>');
		} else {
			insertBlock.push('<a href="javascript:$.goQuickPage(' + i + ')" class="pagenate_txt '+ lastClass +'">'+ i + '</a>');
		}
		
	}
	if(lastPgNum == totPage) {
		insertBlock.push('<span class="btn_pagenate btn_after_quick  btn_dis_type"><span class="screen_out">다음</span></span>');
	} else {
		insertBlock.push('<a href="javascript:$.goQuickPage(\'next\')" class="btn_pagenate btn_after_quick "><span class="screen_out">다음</span></a>');
	}
	
	if(pgnum == totPage) {
		insertBlock.push('<span class="btn_pagenate btn_last_quick  btn_dis_type"><span class="screen_out">마지막</span></span>');
	} else {
		insertBlock.push('<a href="javascript:$.goQuickPage(\'last\',' + totPage + ')" class="btn_pagenate btn_last_quick "><span class="screen_out">마지막</span></a>');
	}
	
	$("#devQuickPaging").append(insertBlock.join('\n'));
};

