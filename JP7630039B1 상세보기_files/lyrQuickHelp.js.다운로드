		$('#devQuickFileNm').val(filename);
	}
});

// Q&A 등록
$("#devQnaRegist").on('click', function() {
	
	if ($("#devQuickSelbox").val() === "" || $("#devQuickSelbox").val() == "default") {
		alert ("문의 유형을 선택해주세요.");
		$('#devQuickSelbox').focus();
		return;
	}
	
	if ($('#devQuickTi').val().trim() === "") {
		alert ("제목을 입력해주세요.");
		$('#devQuickTi').focus();
		return;
	}
	
	if ($('#devQuickCntnt').val().trim() === "") {
		alert ("내용을 입력해주세요.");
		$('#devQuickCntnt').focus();
		return;
	}
	
	var form = $('form[id="devQnaForm"]')[0];
	var formData = new FormData(form);
    formData.append("ctgrCd", $("#devQuickSelbox").val());
    formData.append("emailRplyYn", $("#devQuickEmailRplyYn").prop("checked"));
    formData.append("kakaoRplyYn", $("#devQuickKakaoRplyYn").prop("checked"));
    formData.append("scrtYn", true);
    
	
	$.ajax({
		url: "../lyr/insertQna.wips",
		type: 'POST',
		dataType: 'json',
		processData: false,
        contentType: false,
        data: formData,
        global: false,
		success: function(data) {
			alert("고객님의 문의가 고객센터 1:1 문의에 등록되었습니다.\n문의사항에 대하여 신속하게 답변 드리겠습니다");
			$('#devQnaForm').find('input, textarea').val('');
			$("#devQuickSelbox").val('default');
			$("#devQuickEmailRplyYn").prop("checked",false);
			$("#devQuickKakaoRplyYn").prop("checked",false);
			$("#devQuickScrtYn").prop("checked",false);
			
		}
	});
	
});
$.fn.showHistoryLoadingbar = function(objId) {
	var opts = {
		      lines: 11             // The number of lines to draw
		    , length: 7             // The length of each line
		    , width: 5              // The line thickness
		    , radius: 10            // The radius of the inner circle
		    , scale: 0.6            // Scales overall size of the spinner
		    , corners: 1            // Roundness (0..1)
		    , color: '#000000'         // #rgb or #rrggbb
		    , rotate: 0             // Rotation offset
		    , direction: 1          // 1: clockwise, -1: counterclockwise
		    , speed: 1              // Rounds per second
		    , trail: 100            // Afterglow percentage
		    , fps: 20               // Frames per second when using setTimeout()
		    , zIndex: 2e9           // Use a high z-index by default
		    , shadow: false         // Whether to render a shadow
		    , hwaccel: false        // Whether to use hardware acceleration (might be buggy)
		    , position: 'absolute'  // Element positioning
	    	, top: '50%'
		    , left: '50%'
	};
	var target = document.getElementById(objId);
    var spinner = new Spinner(opts).spin(target);
    $('#'+objId).show();
};

$.fn.hideHistoryLoadingbar = function(objId) {
	$('#'+objId).hide();
	$('#'+objId).html('');
};
