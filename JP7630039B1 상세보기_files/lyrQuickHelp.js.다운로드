// faq 리스트 클릭 (고객센터 새 창 이동)
$.goFaqCntnt = function(brdId, rnum) {
	var form = document.createElement('form');
	var brdSectCd = $("li[id^='devCtgrClass'][class='on']").attr("id").replace('devCtgrClass', '') + '%';
	
	$(form).attr('action', '../cts/faqCntnt.wips')
	   .attr('id', 'lyrQuickHelpFaqForm')
	   .attr('method', 'get')
	   .attr('target', '_blank');
	$(form).html('<input type="hidden" name="brdId" value="' + brdId + '"/>' + 
	'<input type="hidden" name="rnum" value="' + rnum + '"/>' +
	'<input type="hidden" name="srchText" value="' +  $("#devQuickSrchTxt").val() + '"/>' +
	'<input type="hidden" name="brdSectCd" value="'+brdSectCd+'"/>');
	
	document.body.appendChild(form);
	
	$(form).submit();
	
	$('form#lyrQuickHelpFaqForm').remove();	

};

