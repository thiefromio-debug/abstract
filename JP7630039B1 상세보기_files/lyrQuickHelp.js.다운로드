

//quick help menu click
$('.list_quick>li>button').on('click', function(){
	
	var befClassNm = $('.show').attr('class'),
		classNm = $(this).parents('li').attr('class');

	$('.list_quick>li').removeClass('show'); // initial
	$('.quick_block .content_wrap').stop().slideUp(); // initial
	
	
	if (befClassNm != "undefined" && befClassNm === classNm) {
		$('.list_quick_wrap ').stop().slideUp(function(){
			$('.quick_block').removeClass('on');
		});
		return;
	}
	
	if (classNm === 'kakao') {
		$.ajax({
		    type: "post",
		    url: "../lyr/qnakakao.wips",
		    dataType: "json",
		});
		window.open('https://pf.kakao.com/_NZSxku/chat', 'kakao', 'top=100px, left=100px, height=645px, width=465px');

	} else {
		$(this).parents('li').addClass('show');
		$('.list_quick').addClass('on');
		$(this).siblings('.content_wrap').stop().slideDown();
		
		if (classNm === 'faq') {
			$("#devQuickPgnum").val(1);
			$.selectFaq();
		} else if(classNm === 'manual'){
			$("#devQuickManuPgnum").val(1);
		}
	}
	
	
});

//Q&A 글자 수 check
$('#devQuickCntnt').keyup(function (){
    var cntnt = $(this).val();
    if(cntnt.length > 500) {
    	$(this).val($(this).val().substr(0, 500));
    	cntnt = $(this).val();
    }
    $('#devQuickCntntCnt').html(cntnt.length);
});
$('#devQuickCntnt').keyup();

// quick_block 마우스오버 
$('.quick_block').not($('.quick_block .content_wrap')).on('mouseenter', function(){
	$('.quick_block').addClass('on');
	$('.list_quick_wrap').stop().slideDown();
	if($('.list_quick_wrap').css('overflow') == 'hidden') {
		$('.list_quick_wrap').css('overflow','visible');
	}
});
$('.quick_block').on('mouseleave', function(){
	if( !($('.list_quick>li').hasClass('show')) ){
		$('.list_quick_wrap').stop().slideUp(function(){
			$('.quick_block').removeClass('on');
		});
	}
});

// x button
$('.quick_block .btn_close, .quick_block .btn_cancel').on('click', function(){
	$('.list_quick>li').removeClass('show');
	$('.list_quick').removeClass('on');
	$('.quick_block .content_wrap').stop().slideUp();
});

$.selectUserManual = function() {
	var keyword = $("#devQuickManuSrchTxt").val(),
		pgnum = $("#devQuickManuPgnum").val(),
		pgrow = 5;
	if(keyword.replace(/(\s*)/g, "") == ""){
		alert('검색어를 입력해 주세요.')
		return;
	}
	$.fn.showHistoryLoadingbar('devQuickManualLoadingbar');

	$.ajax({
		url: "../cts/ctsManualSearch.wips",
		type: 'POST',
		cache: false,
		async: true,
		dataType: 'json',
		global: false, 
		data: {
			keyword : keyword,
			type : 'M',
			pgnum: pgnum,
			pgrow: pgrow
		},
		success: function(data, textStatus, jqXHR) {
			$.createUserManualListHtml(data);
			$("#rsltKeyword").text(data.ctsManualParamVO.keyword);
			$("#rsltCount").text(data.ctsManualResultVO.manuCount);
			var keywordArray = data.ctsManualParamVO.keyword.replace(/"/g,"").split(" ");
			$.fnKeyWordHighlights(keywordArray);	
			$(".manual_results_box").show();
			$(".search_results_box").show();
			$.fn.hideHistoryLoadingbar('devQuickManualLoadingbar');
		}
	});
}

