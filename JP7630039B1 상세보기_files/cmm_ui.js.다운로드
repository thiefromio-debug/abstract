//검색영역 공통 > 3depth UI 공통길이 설정 이벤트
function sch_3depthHeightEvent(){
	$('.area_dividing,.area_dividing2,.area_dividing3').removeAttr( 'style' );
	
	var sch_3depthHeight_01 = $('.cmm_menuDepth3_checkList .area_dividing1');
	var sch_3depthHeight_02 = $('.cmm_menuDepth3_checkList .area_dividing2');
	var sch_3depthHeight_03 = $('.cmm_menuDepth3_checkList .area_dividing3');
	
	var sch_3depthHeight_all = [sch_3depthHeight_01.outerHeight(),sch_3depthHeight_02.outerHeight(),sch_3depthHeight_03.outerHeight()];
	var sch_3depthHeight_max = Math.max.apply(null, sch_3depthHeight_all);

	$('.area_dividing,.area_dividing2,.area_dividing3').css({"height":sch_3depthHeight_max});
};

