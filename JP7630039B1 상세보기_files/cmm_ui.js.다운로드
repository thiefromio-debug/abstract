//선택 영역 open
function onOffOptionLayer() {
	
	var layerText = $('.js_cmmSubMenu_fold .fold_text').text();
	
	if (layerText === "접기") {
		$('.js_cmmSubMenu_fold .fold_text').text('열기');
		$('.js_cmmSubMenu_fold .fold_text').parent().removeClass('on');	
		$('#cmm_header .cmm_menuDepth3_checkList').hide();
		$('.js_cmmSubMenu_fold span').eq(1).removeClass('ico_arrowUp_orange').addClass('ico_arrowDown_gray');
		$(".info_selectoption").show();
		sch_3depthHeightEvent();
	} else if(layerText === "열기") {
		$('.js_cmmSubMenu_fold .fold_text').text('접기');
		$('.js_cmmSubMenu_fold .fold_text').parent().addClass('on');	
		$('#cmm_header .cmm_menuDepth3_checkList').show();	
		$('.js_cmmSubMenu_fold span').eq(1).removeClass('ico_arrowDown_gray').addClass('ico_arrowUp_orange');	
		$(".info_selectoption").hide();
		sch_3depthHeightEvent();
	}
};

// 도움말 layer on/off
function onOffHelpLayer() {
	var helpBtn_node = $('.btn_cmm_help').offset();
	var helpLayer_width = $('#devHelpLayer').width() - $('.btn_cmm_help').width();
	var helpLayer_node = helpBtn_node.left - helpLayer_width;
	
		$('#devHelpLayer').css({'left':helpLayer_node});	
		
	if ($('#devHelpLayer').is(':visible')) {
		$('#devHelpLayer').hide();
	} else {
		$('#devHelpLayer').show();
	}	
};

