		scope.docVar.docCitnVO.docCitnPatParamVO.pageNum = 1;
		scope.docVar.docCitnVO.docCitnPatParamVO.pageRow = DocCmmConst.CITN_PAGE_ROW;
		scope.docVar.docCitnVO.docCitnPatParamVO.subType = 0;
		scope.docVar.docCitnVO.docCitnPatParamVO.listFilter = 0;
		scope.docVar.docCitnVO.headerList = [
		                       		       {id:'chk', fieldNm:'', sortField:'', sortType:'', arrClass:''}   		//check
		                       		     , {id:'DEPTH', fieldNm:'Depth', sortField:'lvl', sortType:'ASC', arrClass:'ico_arralign ico_default', thClass:'tb_head_backcolor'}   	//Depth
		                       		     , {id:'CC', fieldNm:'국가', sortField:'ctry', sortType:'DESC', arrClass:'ico_arralign ico_default', thClass:'tb_head_backcolor'}   	//국가
		                       		     , {id:'AN', fieldNm:'문헌번호', sortField:'appl_num', sortType:'', arrClass:''}   //문서번호
		                       		     , {id:'S', fieldNm:'인용참증단계', sortField:'', sortType:'', arrClass:''}   			 //유형 -> 인용참증단계(2015-12-17 항목명 수정)
		                       		     , {id:'AD', fieldNm:'공개일', sortField:'appl_dt', sortType:'', arrClass:''}   	 //공개일
		                       		     , {id:'appt', fieldNm:'출원인', sortField:'', sortType:'', arrClass:''}   		 //발명의 명칭
		                       		];
		
		
		// 전체 카운트
		scope.docVar.docCitnVO.pageCountVO.totRsltCnt = 0;
		// 인용 건수
		scope.docVar.docCitnVO.pageCountVO.backRsltCnt = 0;
		// 피인용 건수
		scope.docVar.docCitnVO.pageCountVO.forRsltCnt = 0;
		// 중복 건수
		scope.docVar.docCitnVO.pageCountVO.duplRsltCnt = 0;
		// 전체 페이지수 
		scope.docVar.docCitnVO.pageCountVO.totPageCnt = 1;
		// 보유 건수
		scope.docVar.docCitnVO.pageCountVO.holdCnt = 0;
		// 미보유 건수 
		scope.docVar.docCitnVO.pageCountVO.missingDocCount = 0;
		// 전체건수 class
		scope.docVar.docCitnVO.totClass = 'font_type_bold page_backcolor_step1_text ie7_valignerror_linktext';
		// 인용건수 class
		scope.docVar.docCitnVO.backClass = 'ie7_valignerror_text';
		// 피인용건수 class
		scope.docVar.docCitnVO.forClass = 'ie7_valignerror_text';
		// 심사관/심판 참증 단계 보기
		scope.docVar.docCitnVO.typeChk = 0;
		
		scope.findCitnList = function() {
			
			// 변수 docCmmVar 및 docCmmConst 로 빼기.
			var url = "../doc/findCitn.wips";
			var obj = { skey : scope.docVar.docCitnVO.docCitnPatParamVO.skey
						, sortField : scope.docVar.docCitnVO.docCitnPatParamVO.sortField
						, sortType : scope.docVar.docCitnVO.docCitnPatParamVO.sortType
						, pageNum : scope.docVar.docCitnVO.docCitnPatParamVO.pageNum
						, pageRow : scope.docVar.docCitnVO.docCitnPatParamVO.pageRow
						, subType : scope.docVar.docCitnVO.docCitnPatParamVO.subType
						, listFilter : scope.docVar.docCitnVO.docCitnPatParamVO.listFilter
					  };

			$http.post(url, $.param(obj),{
				headers: {'Content-Type': scope.docConst.JSON_CONT_TYPE}
			}).success(function(data){
				// 전체 skey
				scope.docVar.docCitnVO.skeys = data.skeys;
				scope.docVar.docCitnVO.allChk = false;
				// 보유목록
				scope.docVar.docCitnVO.rsltList = data.citnList;
				
				//checkbox 초기화
				if(scope.docVar.docCitnVO.rsltList != null && scope.docVar.docCitnVO.rsltList.length > 0 ){
					
					for(var i=0; i < scope.docVar.docCitnVO.rsltList.length; i++){
						scope.docVar.docCitnVO.rsltList[i].chk = false;
					}
				}
				
				// 미보유 목록
				scope.docVar.docCitnVO.missingList = data.citnNoneList;
				// 전체 건수
				if(scope.docVar.docCitnVO.pageCountVO != null && data.citnCnt != null){
					scope.docVar.docCitnVO.pageCountVO.totRsltCnt = data.citnCnt.totRsltCnt + data.citnCnt.totNoneRsltCnt;
					// 인용 건수
					scope.docVar.docCitnVO.pageCountVO.backRsltCnt = data.citnCnt.backRsltCnt + data.citnCnt.noneBackRsltCnt;
					// 피인용 건수
					scope.docVar.docCitnVO.pageCountVO.forRsltCnt = data.citnCnt.forRsltCnt + data.citnCnt.noneForRsltCnt;
					// 전체 페이지
					if(data.citnCnt.totPageCnt != 0) {
						scope.docVar.docCitnVO.pageCountVO.totPageCnt = data.citnCnt.totPageCnt;
					}
					
					scope.docVar.docCitnVO.pageCountVO.pageNum = scope.docVar.docCitnVO.docCitnPatParamVO.pageNum;
					scope.docVar.docCitnVO.pageCountVO.pageRow = scope.docVar.docCitnVO.docCitnPatParamVO.pageRow;
				}
				scope.clickDevBtnMarker();
				scope.docQueryHighLighter($("form#paramForm :input[name=hl]").val());
				
				scope.docVar.docCitnVO.examnNullChk = false;
				//심사관 단계보기 데이터 null 처리
				if(scope.docVar.docCitnVO.typeChk && scope.docVar.docCitnVO.rsltList.length == 0){
					scope.docVar.docCitnVO.pageCountVO.totRsltCnt = 1;
					scope.docVar.docCitnVO.examnNullChk = true;
				}
				
				// 상세보기 오른쪽 메뉴 레이어 메뉴 수정
				// 인용 건수
				if(scope.docVar.docCitnVO.pageCountVO.backRsltCnt > 0){
					scrollRightSet("devCitn", "인용 ("+scope.docVar.docCitnVO.pageCountVO.backRsltCnt+")");
				}
				// 피인용 건수
				if(scope.docVar.docCitnVO.pageCountVO.forRsltCnt > 0){
					scrollRightSet("devForCitn", "피인용 ("+scope.docVar.docCitnVO.pageCountVO.forRsltCnt+")");
				}
				
			}).error(function(data, status){
				/*if (/EgovBizException/.test(data.responseText)) {
		            alert(data.responseText.match(/EgovBizException: &quot;(.*?)&quot;/)[1]);
		            // error 처리
		        }
		        else {
		            alert("에러가 발생하였습니다. " + status + "\nError: " + data.responseText);
		        }*/
			});
			
		};
		
		/**
		 * 헤더에서 소트키 클릭시
		 */
		scope.citnListSort = function(headerIndex){
			
			for(var i = 0; i < scope.docVar.docCitnVO.headerList.length; i++){
				if(scope.docVar.docCitnVO.headerList[i].sortField === ''){
					continue;
				}
				
				if(i === headerIndex) {
					if(scope.docVar.docCitnVO.headerList[i].sortType === "DESC") {
						scope.docVar.docCitnVO.headerList[i].sortType = "ASC";
						scope.docVar.docCitnVO.headerList[i].arrClass = "ico_arralign ico_arrup";
						//scope.docVar.docCitnVO.headerList[i].thClass = "tb_head_backcolor font_color_orange";
						scope.docVar.docCitnVO.headerList[i].fontClass = "font_color_orange";
					} else {
						scope.docVar.docCitnVO.headerList[i].sortType = "DESC";
						scope.docVar.docCitnVO.headerList[i].arrClass = "ico_arralign ico_arrdown";
						//scope.docVar.docCitnVO.headerList[i].thClass = "tb_head_backcolor font_color_orange";
						scope.docVar.docCitnVO.headerList[i].fontClass = "font_color_orange";
					}
					scope.docVar.docCitnVO.docCitnPatParamVO.sortField = scope.docVar.docCitnVO.headerList[i].sortField;
					scope.docVar.docCitnVO.docCitnPatParamVO.sortType = scope.docVar.docCitnVO.headerList[i].sortType;
					
				} else {
					scope.docVar.docCitnVO.headerList[i].arrClass = "ico_arralign ico_default";
					//scope.docVar.docCitnVO.headerList[i].thClass = "tb_head_backcolor";
					scope.docVar.docCitnVO.headerList[i].fontClass = "";
				}
				/*else {
					scope.docVar.docCitnVO.headerList[i].arrClass = "";
				}*/
			}
			
			scope.findCitnList();
		};
		
		/**
		 * 서브통계 클릭시
		 */
		scope.citnListSubSelect = function(subType){
			
			scope.docVar.docCitnVO.docCitnPatParamVO.subType = subType;
			
			// 페이징 리셋
			scope.docVar.docCitnVO.docCitnPatParamVO.pageNum = 1;
			if(subType == 0) {
				// 전체건수 class
				scope.docVar.docCitnVO.totClass = 'font_type_bold page_backcolor_step1_text ie7_valignerror_linktext';
				// 인용건수 class
				scope.docVar.docCitnVO.backClass = 'ie7_valignerror_text';
				// 피인용건수 class
				scope.docVar.docCitnVO.forClass = 'ie7_valignerror_text';
			} else if(subType == -1) {
				// 전체건수 class
				scope.docVar.docCitnVO.totClass = 'page_backcolor_step1_text ie7_valignerror_linktext';
				// 인용건수 class
				scope.docVar.docCitnVO.backClass = 'ie7_valignerror_text font_type_bold';
				// 피인용건수 class
				scope.docVar.docCitnVO.forClass = 'ie7_valignerror_text';
			} else if (subType == 1) {
				// 전체건수 class
				scope.docVar.docCitnVO.totClass = 'page_backcolor_step1_text ie7_valignerror_linktext';
				// 인용건수 class
				scope.docVar.docCitnVO.backClass = 'ie7_valignerror_text';
				// 피인용건수 class
				scope.docVar.docCitnVO.forClass = 'ie7_valignerror_text font_type_bold';
			} 
			
			scope.findCitnList();
		};
		
		
		/**
		 * 이전페이지 클릭시
		 */
		scope.prevPageCitn = function(){
			if(scope.docVar.docCitnVO.docCitnPatParamVO.pageNum == 1){
				//alert('첫번째 페이지입니다.');
				return;
			}
			
			scope.docVar.docCitnVO.docCitnPatParamVO.pageNum = scope.docVar.docCitnVO.docCitnPatParamVO.pageNum - 1;
			scope.findCitnList();
		};
		
		/**
		 * 다음페이지 클릭시
		 */
		scope.nextPageCitn = function(){
			if(scope.docVar.docCitnVO.docCitnPatParamVO.pageNum == scope.docVar.docCitnVO.pageCountVO.totPageCnt){
				//alert('마지막 페이지 입니다.');
				return;
			}
			
			scope.docVar.docCitnVO.docCitnPatParamVO.pageNum = scope.docVar.docCitnVO.docCitnPatParamVO.pageNum + 1;
			scope.findCitnList();
		};

		/**
		 * 인용분석 링크 
		 */
		scope.openCitnAnalysis = function(){
			var url = "../cia/ciaSearch.wips";
			var form = document.createElement('form');
			$(form).attr('action', url)
				   .attr('id', 'citaParamForm')
				   .attr('method', 'get')
				   .attr('target', '_blank');
			$(form).html('<input type="hidden" name="skey" value="' + scope.docVar.docCitnVO.docCitnPatParamVO.skey +'" />' );
			document.body.appendChild(form);

			$(form).submit();
			$('form#citaParamForm').remove();	
		};
		
		
		//원문 아이콘 class
		scope.pdfIconClass = function(pdfGb, ctry) {
			if(ctry == "CA"){
				pdfGb = 0;
			}
			
			if(pdfGb == 1 || pdfGb == 2) {
				return 'btn_openpdf';
			}
			else { // null
				return "btn_dispdf";
			}
		};
		
		//인용/피인용 레벨 단계 변환
		scope.lvlConvert = function(lvl) {
			var depth = "";
			
			if(lvl.indexOf(',') != -1){
				lvl = lvl.split(',');
				
				lvl.forEach(function(i){
					if(depth.length > 1){
						depth += ",";
					}
					
					if(i == "-1"){
						depth += "B1";
					} else if(i == "1"){
						depth += "F1";
					}
				});
			} else {			// 단일 레벨
				if(lvl == "-1"){
					depth += "B1";
				} else if(lvl == "1"){
					depth += "F1";
				}
			}
			
			return depth;
		};
		
		/**
		 * Citn Type 변경
		 */
		scope.typeChkChangeCitn = function(){
			if(scope.docVar.docCitnVO.typeChk == 1){
				scope.docVar.docCitnVO.typeChk = 0;
			} else {
				scope.docVar.docCitnVO.typeChk = 1;
			}
			
			scope.docVar.docCitnVO.docCitnPatParamVO.listFilter = scope.docVar.docCitnVO.typeChk;
			scope.docVar.docCitnVO.docCitnPatParamVO.pageNum = 1;
			scope.findCitnList();
		};
		
	};
