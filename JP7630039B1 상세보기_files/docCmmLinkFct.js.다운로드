	function openPopupUrl(url, popupName, paramList, width, height, toolbar, menubar, status, scrollbars, resizable, copyhistory){
		$("body").focus();
		var winHeight = document.body.clientHeight; //현재창의 높이 
		var winWidth = document.body.clientWidth; //현재창의 너비 
		var winX = window.screenLeft; //현재창의 x좌표 
		var winY = window.screenTop; //현재창의 y좌표 
		
		var left = winX + (winWidth - width)/2; 
		var top = winY + (winHeight - height)/2;
		
		for(var i=0; paramList != null && i < paramList.length; i++){
			if(i == 0){
				url += "?";
			}else{
				url += "&";
			}
			url += paramList[i].fieldNm + "=" + paramList[i].fieldValue;
		}
		
		var popUpView = window.open(url,popupName,'left=' + left + ',top=' + top + ',width=' + width + ',height=' + height + ',toolbar=' + toolbar + ',menubar=' + menubar + ',status=' + status + ',scrollbars=' + scrollbars + ',resizable=' + resizable + ',copyhistory=' + copyhistory);
		
		if(popUpView != null){
			popUpView.focus();
		}
	};
	
	function openSubmitPopup(url, popupName, formName, formMethod, paramList, width, height, toolbar, menubar, status, scrollbars, resizable, copyhistory){
		var winHeight = document.body.clientHeight; //현재창의 높이 
		var winWidth = document.body.clientWidth; //현재창의 너비 
		var winX = window.screenLeft; //현재창의 x좌표 
		var winY = window.screenTop; //현재창의 y좌표 
		
		var left = winX + (winWidth - width)/2; 
		var top = winY + (winHeight - height)/2;
		
		var frm = document.createElement('form');
		frm.setAttribute('method', formMethod);
		frm.setAttribute('action', url);
		frm.setAttribute('name', formName);
		frm.setAttribute('id', formName);
		frm.setAttribute('target', popupName);
		
		for(var i=0; paramList != null && i < paramList.length; i++){
			var popParamDom = document.createElement('input');
			popParamDom.setAttribute('type', 'hidden');
			popParamDom.setAttribute('name', paramList[i].fieldNm);
			popParamDom.setAttribute('value', paramList[i].fieldValue);
			frm.appendChild(popParamDom);
		}
		
		document.body.appendChild(frm);
		
		var popUpView = window.open("../html/cmm/popup_blank.html",popupName,'left=' + left + ',top=' + top + ',width=' + width + ',height=' + height + ',toolbar=' + toolbar + ',menubar=' + menubar + ',status=' + status + ',scrollbars=' + scrollbars + ',resizable=' + resizable + ',copyhistory=' + copyhistory);
		
		if(popUpView == null){
			$('form#' + formName).remove();
			alert("차단된 팝업을 허용해 주십시오.");
		}else{
			frm.submit();
			$('form#' + formName).remove();
			popUpView.focus();
		}
	};
	

