                                <thead>
                                    <tr>
	                                    <th class="tb_head_backcolor">원문</th>
	                                    <th class="tb_head_backcolor">유형</th>
	                                    <th class="tb_head_backcolor">출원번호</th>
	                                    <th class="tb_head_backcolor">문헌번호</th>
	                                    <th class="tb_head_backcolor"><a href="javascript:void(0);" ng-click="relApplListSortUs(4)" ng-class="docVar.dusRelApplVO.headerList[4].fontClass"><span ng-bind-html="docVar.dusRelApplVO.headerList[4].fieldNm"></span><span ng-class="docVar.dusRelApplVO.headerList[4].arrClass"><!-- --></span><!-- 정렬 내림차순 Class명 ico_arrdown 변경--></a></th>
	                                    <th class="tb_head_backcolor font_align_left">발명의 명칭</th>
                                	</tr>
                                </thead>
                                <tbody>
                                    <tr ng-show="docVar.dusRelApplVO.rsltList.length == 0">
                                		<td colspan="7" class="font_align_center" ng-class="updateDocFontOption();">
                                			<p>해당 정보가 없습니다.</p>
                                		</td>
