                                        </td>
                                   </tr>
                                </tbody>
                            </table>
                            <div class="remark_footblock">
                              <p ng-hide="docVar.dusRelApplVO.provisionalList.length <= 0">
                              	<span class="title_text">* Provisional</span>
                              	<span ng-repeat="provision in docVar.dusRelApplVO.provisionalList"> 
                                 <span ng-class="{'font_color_888': true, 'text_divbar': !$last, 'float_l': $last}" ng-bind-html="provision.ctry + ' ' + provision.applNum + ' ' + provision.applDt"></span>
                                </span>
                              </p> 
                              <p ng-hide="docVar.dusRelApplVO.missingList.length <= 0">
                              	<span class="title_text2">* 미포함 문헌 : <span ng-bind="docVar.dusRelApplVO.pageCountVO.missingDocCount" ></span>건 (절차상 미공개 문헌, 과거분 문헌, WIPS 보유 데이터 범위에 포함되지 않는 문헌)</span>
                                <span ng-repeat="missing in docVar.dusRelApplVO.missingList"> 
                                 <span ng-class="{'font_color_888': true, 'text_divbar': !$last, 'float_l': $last}" ng-bind-html="missing.ctry + ' ' + missing.applNum + ' ' + missing.applDt"></span>
                                </span>
                              </p> 
                            </div>
                            <div class="list_space"><!-- --></div> 
                        </div>
					</div>
                */
		});
		
		elm.html($compile(innerHtml)(scope));
		
		scope.findRelApplList();
	};
	
	
}]);