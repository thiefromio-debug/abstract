                                   	<tr ng-show="docVar.dusRelApplVO.rsltList.length > 0" ng-repeat="relAppl in docVar.dusRelApplVO.rsltList">
                                        <td class="font_align_center" ng-class="updateDocFontOption();">
	                                    	<a ng-hide="relAppl.pdfGb == '0'" doc-pdf-split-func-dtv ng-model="relAppl.applNum" pdf-skey="{{relAppl.skey}}" ng-class="relAppl.pdfClass + ' marg_auto marg_top_05'"><span class="screen_hide">PDF</span></a>
