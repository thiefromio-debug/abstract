                                        <td class="font_align_center" ng-class="updateDocFontOption();">
                                        	<a ng-hide = "relAppl.skey == null || relAppl.skey == ''" doc-link-dtv ng-model="relAppl"><span ng-bind-html="relAppl.applNum"></span></a>
                                        	<span ng-show = "relAppl.skey == null || relAppl.skey == ''" ng-bind-html="relAppl.applNum"></span>
                                        </td>
                                        <td class="font_align_center" ng-class="updateDocFontOption();">
                                        	<a ng-hide = "relAppl.skey == null || relAppl.skey == ''" doc-link-dtv ng-model="relAppl"><span ng-bind-html="relAppl.mngNum"></span></a>
                                        	<span ng-show = "relAppl.skey == null || relAppl.skey == ''" ng-bind-html="relAppl.mngNum"></span>
                                        </td>
                                        <td class="font_align_center" ng-class="updateDocFontOption();"><span ng-bind-html="relAppl.applDt"></span></td>
                                        <td ng-class="updateDocFontOption();">
                                        	<a ng-hide = "relAppl.skey == null || relAppl.skey == ''" doc-link-dtv ng-model="relAppl"><span ng-bind="relAppl.invTi"></span></a>
