			if(imageCurrentSeq > angularScope.docVar.screenVO.clCurImgNum){
				angularScope.docVar.screenVO.clCurImgNum = imageCurrentSeq;
				angularScope.$apply();
			}else if((imageCurrentSeq + imageDisplayCnt - 1) < angularScope.docVar.screenVO.clCurImgNum){
				angularScope.docVar.screenVO.clCurImgNum = (imageCurrentSeq + imageDisplayCnt - 1);
				angularScope.$apply();
