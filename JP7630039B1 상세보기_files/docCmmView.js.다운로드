	$('#devInclude').on('click', '#previousDrawImg', function() {
		
		if(imageCurrentSeq  ==  1){
			$('#previousDrawImg').removeAttr("href");
			$('#previousDrawImg').addClass('btn_dis_type');
		}
		
		if(imageCurrentSeq  ==  0){
			return false;
		}
		
		$(".mini_imgdraw_block").each(function(i){
			if($(this)[0].style.display != "none"){
				imageCurrentSeq = i-1;
				return false;
			}
		});
		$('#nextDrawImg').attr("href","javascript:void(0);");
		$('#nextDrawImg').removeClass('btn_dis_type');
		$.imageDisplayShow(imageCurrentSeq);
		
		//현재 활성화된  이미지가 없으면 활성화 이미지를 제일 뒤 이미지로 처리 한다.
