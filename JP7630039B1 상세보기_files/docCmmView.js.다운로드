function getContentsJsonSuccess(data){
	// [S] 데이터 노출
	// 발명의 설명 VIEW
	if($("#tabGb").val() == "DS"){
		// 데이터 용량데이터 문구 노출
		if(data.docPageDescriptionRsltVO.isOver == true){
			$("#devViewTwoColumn").prop("disabled", true);
			$("#devViewHighLight").prop("disabled", true);
			
			$("#devViewMulti").prop("disabled", true);
			$("#devViewOrigin").prop("disabled", true);
			$("#devViewTrans").prop("disabled", true);
			
			// 분리링크 영역  hide
			if($('#devBigDataMsg').length > 0 ) {
				$('.detail_view_list').hide();
			}
		}
		else{
			// 언어 코드 입력
			langCdList = new Array();
			langTrnsCdList = new Array();
			
			if((data.descList != null && data.descList.length > 1) || $("#ctry").val() == 'WO' || $("#ctry").val() == 'EP'){
				// 언어버튼 데이터 셋팅(원어)
				$.each(data.descList, function(idx, val){
					var tmpLangCdList = {};
					tmpLangCdList.langCd = val.langCd;
					tmpLangCdList.langCdTrns = null;
					langCdList.push(tmpLangCdList);
				});
			}
			//원문 번역문 언어버튼 동시 존재 가능
			if(data.descTrnsList != null && data.descTrnsList.length > 1 || $("#ctry").val() == 'WO' || $("#ctry").val() == 'EP'){
				// 언어버튼 데이터 셋팅(번역)
				$.each(data.descTrnsList, function(idx, val){
					var tmpLangCdList = {};
					tmpLangCdList.langCd = null;
					tmpLangCdList.langCdTrns = val.langCd;
					langTrnsCdList.push(tmpLangCdList);
				});
			}
			
			descList = data.descList;
			//NMT는 오래걸려서 담아둠
			if(!getNmtDataYn){
				descTrnsList = data.descTrnsList;
			}
			
			//WO 프로시저 사용으로 번역문 display 화면에서 처리
			if(!data.descTrnsList || data.descTrnsList.length === 0){
				$("#devViewMulti").attr("disabled", true);
				$("#devViewTrans").attr("disabled", true);
			}
			
			// [S] 언어 버튼 생성
			getContentsLangCd(langCdList, langTrnsCdList, nmtLangCd);
			// [E] 언어 버튼 생성
			
			dataDSView();
			
		}
	}
	// 청구항 VIEW
	else if($("#tabGb").val() == "CL"){
		$("#devRemarkView").html($("#tmplRemarkView").render({clRemarkList:data.clRemarkList}));
		
		clList = data.clList;
		clTrnsList = data.clTrnsList;
		clCnt = data.clCnt;
		if (data.clLangList && Array.isArray(data.clLangList)) {
			// langCdList 필터링
			langCdList = data.clLangList.filter(function(i) {
				return !!i.langCd;
			});
			
			// langTrnsCdList 필터링
			langTrnsCdList = data.clLangList.filter(function(i) {
				return !!i.langCdTrns;
			});
		}
		
		if(data.docPageClaimRsltVO.exmpClSeq != null){
			exmpSeq = data.docPageClaimRsltVO.exmpClSeq.exmpSeq;
		}
		if(data.clTypeList != null){
			clType = data.clTypeList[0].clType;
		}
		
		//대체정보 출처 
		if(data.clReplTag != null){
			dbNm = data.clReplTag.dbNm;
			docKind = data.clReplTag.docKind;
			ctry = data.clReplTag.ctry;
			docNum = data.clReplTag.docNum;
		}

		// [S] 언어 버튼 생성
		
		getContentsLangCd(langCdList, langTrnsCdList, null);
		// [E] 언어 버튼 생성
		
		dataCLView();
		
	}else if($("#tabGb").val() == "FT"){
		
		fullText = data.fullText.fullText;
		if(data.fullTextTrns != null){
			fullTextTrns = data.fullTextTrns.fullText;
		}
		
		dataFTView();
	}
	// [E] 데이터 노출
	
	if ($("#tabGb").val() != "CH") {	//화합물 탭의 경우 나중에 닫는다.
		$.closeLoadingBar();
	}
}

// 청구항, 발명의 설명 언어 버튼 생성
// 24.03.24 원문,번역문에 언어버튼 동시 존재 가능으로 수정
function getContentsLangCd(tmpLangCdList, tmpLangTrnsCdList, nmtLangCd){
	$("#devLangSet").empty();
	$("#devLangTrnsSet").empty();
	
	if((tmpLangCdList != null && tmpLangCdList.length > 0) || (tmpLangTrnsCdList != null && tmpLangTrnsCdList.length > 0)){
		if (tmpLangCdList && tmpLangCdList[0] && tmpLangCdList[0].langCd != null) {
			// 원문
			$("#devLangCd").val(tmpLangCdList[0].langCd.toLowerCase());
		}
		
		if(tmpLangTrnsCdList && tmpLangTrnsCdList[0] && tmpLangTrnsCdList[0].langCdTrns != null){
			// 번역문
			$("#devLangCdTrns").val(tmpLangTrnsCdList[0].langCdTrns.toLowerCase());
		}
		
		if($("#devViewOrigin").prop('checked') && $("#devLangCd").val() != ''){
			$("#devLangSet").html($("#tmplLangSet").render({langList:tmpLangCdList, nmtLangCd:nmtLangCd}));
		}
		else if($("#devViewTrans").prop('checked') && $("#devLangCdTrns").val() != ''){
			$("#devLangSet").html($("#tmplLangSet").render({langList:tmpLangTrnsCdList, nmtLangCd:nmtLangCd}));
		}
		else if($("#devViewMulti").prop('checked')){
			if($("#devLangCd").val() != ''){
				$("#devLangSet").html($("#tmplLangSet").render({langList:tmpLangCdList, nmtLangCd:nmtLangCd}));
			}
			if($("#devLangCdTrns").val() != ''){
				$("#devLangTrnsSet").html($("#tmplLangSet").render({langList:tmpLangTrnsCdList, nmtLangCd:nmtLangCd}));
			}
		}
		else if($("#devViewOrigin").prop('checked') == undefined && $("#devViewTrans").prop('checked') == undefined){
			$("#devLangSet").html($("#tmplLangSet").render({langList:tmpLangCdList, nmtLangCd:nmtLangCd}));
		}
		
	}
	else{
		$("#devLangCd").val('');
		$("#devLangCdTrns").val('');
	}
}
// 출렵옵션 글자 크기 설정
function onChangeFontSize(fontSize) {
	
//	var $resulttext = $(".highlightText, .devDocViewOption td, .scroll_left table td div[name=divCl], .devExampClText, .devAbText");
	var $resulttext = $(".highlightText, .devDocViewOption td, .scroll_left table td p, .devExampClText, .devAbText");
	
	//폰트 사이즈 설정
	$resulttext.removeClass("change_fontsize_large").removeClass("change_fontsize_small").removeClass("change_fontsize_default");
	switch (fontSize) {
	case DocCmmConst.DOC_CONFIG.FONT_SIZE.L:
		$resulttext.addClass("change_fontsize_large");
		$("input:radio[id='devFontsizeLarge']").prop("checked", true);
		break;
	case DocCmmConst.DOC_CONFIG.FONT_SIZE.S:
		$resulttext.addClass("change_fontsize_small");
		$("input:radio[id='devFontsizeSmall']").prop("checked", true);
		break;
	case DocCmmConst.DOC_CONFIG.FONT_SIZE.D:
	default:
		$resulttext.addClass("change_fontsize_default");
		$("input:radio[id='devFontsizeDefault']").prop("checked", true);
		break;
	}
};
