	$.showSelectClaimLangAction = function(lang, fnNm, parentId){
		
		$('#devLangSet span, #devLangTrnsSet span').each(function(){
			if($(this).attr('lang') == lang){
				if(!$(this).hasClass('on')){
					$(this).addClass('on');
					$(this).attr('style', "cursor:default;");
					$(this).attr('onClick', ";");
					$('div[name=divCl'+lang+']').show();
				}
			}
			else{
				if(($(this).parent().attr('id') == parentId) && $(this).hasClass('on')){
					$(this).removeClass('on');
					$(this).attr('style', "cursor:pointer;");
					$(this).attr('onClick', "javascript:"+fnNm+"('" + $(this).attr('lang') + "',event);");
					$('div[name=divCl'+$(this).attr('lang')+']').hide();
				}
			}
		});
		
		if($("#tabGb").val() == "DS"){
			dataDSView();
		}
		else if($("#tabGb").val() == "CL"){
			dataCLView();
		}
		else if($("#tabGb").val() == "FT"){
			dataFTView();
		}
	};
	$.showSelectClaimLang = function(lang,event){
