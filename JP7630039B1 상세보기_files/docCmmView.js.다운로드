	$('#scrollRight1').on('click', 'input', function() {
		// [S] 언어 버튼 생성
		getContentsLangCd(langCdList, langTrnsCdList, null);
		// [E] 언어 버튼 생성
		
		// [S] 뷰모드 설정
		// 뷰모드에 따라 다단보기 설정
		if($(this).prop("id") == "devViewMulti"){
			$('#devViewTwoColumn').prop('checked', true).prop('disabled', true);
			$('#devViewTwoColumn').next().removeClass("on");
		}else{
			if($(this).prop("type") == "radio"){
