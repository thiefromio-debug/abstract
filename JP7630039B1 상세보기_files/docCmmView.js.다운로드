		//skey 없는 문헌은 없으니 그냥 ctry로 먼저 판단.
		if(typeof ctry != "undefined" && ctry != null && ctry != ''){
			if(ctry == "KR"){
				url = "../api/dkrdshtm.wips";
			} else if(ctry == "US"){
				url = "../api/dusdshtm.wips";
			} else if(ctry == "JP"){
				url = "../api/djpdshtm.wips";
			} else if(ctry == "EP"){
				url = "../api/depdshtm.wips";
			} else if(ctry == "WO"){
				url = "../api/dwodshtm.wips";
			} else if(ctry == "CN"){
				url = "../api/dcndshtm.wips";
			} else if(ctry == "PAJ"){
				url = "../api/dpadshtm.wips";
			} else if(ctry == "KPA"){
				url = "../api/dkpdshtm.wips";
			} else {
				url = "../api/dipdshtm.wips";
			}
		} else {	//RA의 경우 ctry값 없음. 국내(원국가)와 pct만 존재, meta데이터 토대로 작성
			var ctryCd = parseInt(skey.substring(0,2));
			if(ctryCd == 10){ //AU
				url = "../api/dipdshtm.wips";
			} else if(ctryCd >= 45 && ctryCd <= 54) {//US
				url = "../api/dusdshtm.wips";
			} else if([55, 56, 58, 60, 80].includes(ctryCd)){//WO
				url = "../api/dwodshtm.wips";
			} else {
				url = "../api/dipdshtm.wips";
			}
		}
		return url;
	});
	
		
