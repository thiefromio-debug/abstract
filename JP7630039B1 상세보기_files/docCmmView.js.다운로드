	// 검색식 하이라이트 체크박스
	$.checkHighlight = function() {
		if($("#devViewHighLight").prop('checked')){
			var className = "font_color_orange";
			var hl = $("#hl").val();
			$(".queryHighlightText").clearHighLight(className);
			if(hl != null && hl != ""){
				var keywordArray = hl.split('||');
				for (var i = 0; i < keywordArray.length; i++) {
					var hlword = keywordArray[i];
					
					if(hlword == "" || hlword == " "){
						continue;
					}
					$(".queryHighlightText").executeHighLight(keywordArray[i], className);
			    }	
			}
		} else if(!$("#devViewHighLight").prop('checked')){
			var className = "font_color_orange";
			$('.queryHighlightText').clearHighLight(className);
		}
		
		if($("#chem").val() === 'Y'){
			highlightDraw();
		}
	}
	
