					$('#devViewTwoColumn').next().removeClass("on");
				}
			}
		}
		// 라디오버튼, 체크박스 선택시 라벨 볼드처리
		if($(this).prop("type") == "radio"){
			
			$("input[name=viewModeRadio]").next().removeClass("on");
			$(this).next().addClass("on");
			
		}else if($(this).prop("type") == "checkbox"){
			if($(this).prop("checked") == true){
				$(this).next().addClass("on");
			}else{
				$(this).next().removeClass("on");
			}
		}
		// [E] 뷰모드 설정
		
		// 뷰모드 변경에 따른 데이터 출력
		if($("#tabGb").val() == "DS"){
			dataDSView();
		}
		else if($("#tabGb").val() == "CL"){
			dataCLView();
		}
		else if($("#tabGb").val() == "FT"){
			dataFTView();
		}

