		scope.docQueryHighLighter = function(hl){
			var className = "font_color_orange";
			$(".queryHighlightText").clearHighLight(className);
			if(hl != null && hl != ""){
				var keywordArray = hl.split('||');
				for (var i = 0; i < keywordArray.length; i++) {
					var hlword = keywordArray[i];
					
					if(hlword == "" || hlword == " "){
						continue;
					}
					
					if(scope.docVar.screenVO.tabGb == DocCmmConst.TABGB.AB){ //요약정보 탭일경우 JSON 처리						
						//요약 하이라이트 처리
						switch (scope.docVar.screenVO.serviceNm){
						case DocCmmConst.SERVICENM.DCN:
						case DocCmmConst.SERVICENM.DDB:
						case DocCmmConst.SERVICENM.DEP:
						case DocCmmConst.SERVICENM.DJP:
						case DocCmmConst.SERVICENM.DLN:
						case DocCmmConst.SERVICENM.DWO:
							{
								for(var j=0; j < scope.docVar.docPageSummaryRsltVO.abList.length; j++){
									var rsltObj = getJsonDataHighlight(scope.docVar.docPageSummaryRsltVO.abList[j].ab, hlword, className);
									// 요약정보 xml 태그 삭제
									var rsltObjAbHtml = rsltObj.html.replace(/(<\?xml([^>]+)>)/gi, "");
									scope.docVar.docPageSummaryRsltVO.abList[j].ab = rsltObjAbHtml;
								}
								for(var j=0; j < scope.docVar.docPageSummaryRsltVO.exmpClList.length; j++){
									var rsltObj = getJsonDataHighlight(scope.docVar.docPageSummaryRsltVO.exmpClList[j].exmpCl, hlword, className);
									// 요약정보 xml 태그 삭제
									var rsltObjAbHtml = rsltObj.html.replace(/(<\?xml([^>]+)>)/gi, "");
									scope.docVar.docPageSummaryRsltVO.exmpClList[j].exmpCl = rsltObjAbHtml;
								}
							}
							break;
						case DocCmmConst.SERVICENM.DJT:
						case DocCmmConst.SERVICENM.DKP:
						case DocCmmConst.SERVICENM.DKR:
						case DocCmmConst.SERVICENM.DKT:
