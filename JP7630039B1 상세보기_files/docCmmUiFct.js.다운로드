			} else if($('#ctry').val() =='CN') {
				url = "../dcn/findDrwImage.wips";
			} else if($('#serviceNm').val() == 'DLN') {
				url = "../dln/findDrwImage.wips";
			} else if($('#ctry').val() == 'AU') {
				url = "../dau/findDrwImage.wips";
			} else if($('#ctry').val() == 'WO') {
				url = "../dwo/findDrwImage.wips";
			} else if($('#ctry').val() =='USPAST') {
				url = "../dut/findDrwImage.wips";
			}

			if(url != ''){
				$.ajax({
					type: "post",
					url: url,
					data: {
						skey: $('#skey').val()
					},
					dataType: "json",
					async: false,
					success: function(data, textStatus) {
						drwImgList 	= data.drwImgList;
						scope.docVar.screenVO.drwImgList = drwImgList;
						$.resultDevDrw(drwImgList, 0, 3);
						
					}
				});
			}
		};

		/**
		* 전체도면 버튼 클릭시 개별도면 조회 Result
		*/
		$.resultDevDrw = function(drwImgList, start, end) {
			if(start == undefined){
				start = 0;
			}
			if(end == undefined || end > drwImgList.length){
				end = drwImgList.length;
			}
			if(start > end){
				return false;
			}
			
			//대체 개별도면 표시
			if(drwImgList.length > 0 && (drwImgList[0].tag != null && drwImgList[0].tag != "") && $("#ctry").val() == "EP"){
				scope.docVar.docPageSummaryRsltVO.drwImgTag = drwImgList[0].tag;
				if($("#devDrgImgTag").length < 1){
					if($("#devDrwTag").length > 0){
						$("#devDrwTag").append("<span id='devDrgImgTag'> ," + scope.docVar.docPageSummaryRsltVO.drwImgTag + "</span>");
					} else {
						$("#devDrwInfo").append("<span id='devDrgImgTag'>↓ " + scope.docVar.docPageSummaryRsltVO.drwImgTag + "</span>");
					}
				}
			}
			
			for (var i = start ; i < end ; i++) {
				var drwUrl = drwImgList[i].drwUrl
					, seq = drwImgList[i].seq
					, rnum = i+1
					, skey = drwImgList[i].skey
					, drwNum = drwImgList[i].drwNum
					, insertHtml = [];
				
				/*if($('#ctry').val() =='IN') {
					seq = drwImgList[i].rnum;
				} */
				if(drwNum == null ) {
					drwNum = '';
				}
				insertHtml.push('<li class="mini_imgdraw_block');
				if(i >= 3){insertHtml.push(' _2depth');}
				insertHtml.push('" ng-class="{\'on\' : docVar.screenVO.abCurImgNum == ' + (i+1) + '}"');
				
				insertHtml.push('>');
				
				insertHtml.push('<table>');
				insertHtml.push('<tr>');
				insertHtml.push('<td align="middle" class="img_area" ng-click="onClickDrw(' + skey + ',' + rnum + ');">');
				insertHtml.push('<a href="javascript:void(0);">');
				insertHtml.push('<img src="' + drwUrl + '" alt="도면이미지" />');
				insertHtml.push('</a>');
				insertHtml.push('</td>');
				insertHtml.push('</tr>');
				insertHtml.push('<tr>');
				insertHtml.push('<td class="font_size_11"><div class="draw_txt_ellipsis">도면 ' + drwNum + '</div></td>');
				insertHtml.push('</tr>');
				insertHtml.push('</table>');
				insertHtml.push('</li>');
				$('#devDrwImage').append($compile(insertHtml.join('\n'))(scope));
			}
			
			if(end > 3){
				$("#devScreenHide").toggle();
			}
		}
		
