		scope.openImagePopup = function(skey,seq) {
			$("a").blur();
			var winHeight = document.body.clientHeight; //현재창의 높이 
			var winWidth = document.body.clientWidth; //현재창의 너비 
			var winX = window.screenLeft; //현재창의 x좌표 
			var winY = window.screenTop; //현재창의 y좌표 
			
			var url		= "../lyr/popDrawing.wips",
				name		= "_imgPopup",
				width 	= 1150,
				height 	= 720,
				left 		= winX + (winWidth - width)/2, 
				top 		= winY + (winHeight - height)/2,
				imgPopup	= null,
				form 		= document.createElement('form');
			
			$(form).attr('action', url)
					.attr('id', 'docDrawPopUpView')
					.attr('method', 'post')
					.attr('target', name);
			
			$(form).html('<input type="hidden" name="skey" value="' + skey +'" />'
					+ '<input type="hidden" name="rDetailImageNum" value="' + seq +'" />');
			
			document.body.appendChild(form);
			
			imgPopup = window.open("../html/cmm/popup_blank.html", name, 'left=' + left + ',top=' + top + ',width=' + width + ',height=' + height + ',toolbar=0,menubar=0,status=1,scrollbars=0,resizable=1,copyhistory=0');
			
			if (imgPopup === null) {
				alert("차단된 팝업을 허용해 주십시오.");
			} else {
				$(form).submit();
				$('form#devExmpImgForm').remove();
				imgPopup.focus();
			}
			
			if(scope.docVar.screenVO.tabGb == scope.docConst.TABGB.AB){
				scope.docVar.screenVO.abCurImgNum = seq;
			}else if (scope.docVar.screenVO.tabGb == scope.docConst.TABGB.CL){
				scope.docVar.screenVO.clCurImgNum = seq;
			}else if (scope.docVar.screenVO.tabGb == scope.docConst.TABGB.DS){
				scope.docVar.screenVO.descCurImgNum = seq;
			}
			
		};
