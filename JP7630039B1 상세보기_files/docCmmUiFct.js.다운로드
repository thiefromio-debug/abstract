		/**
		 * 형광펜 클릭시 형광펜 하이라리트 처리
		 */
		scope.clickDevBtnMarker = function(){
			// 청구항, 발명의 설명 에서만 적용
			if(!(scope.docVar.screenVO.tabGb == "CL" || scope.docVar.screenVO.tabGb == "DS")){
				return false;
			}
			
			$('input[name=marker]').each(function(i){
				if($(this).attr('class').indexOf('highlight_color')> 0){
					var className = 'highlight_text' + $('input[name=highlightersClass]').eq(i).val();
					//its 7854 처리
					var hlword = $(this).val().replace(/(^\s*)|(\s*$)/gi, '');
					$('.highlightText').clearHighLight(className);
					
					if(hlword.lastIndexOf('(\u200B') > -1){
						hlword = hlword.substring(0, hlword.lastIndexOf('(\u200B'));
					}
					
					if(hlword.length == 0){
						//$('input[name=highlighters]').eq(i).val(hlword);
						//$('.devHighlightNg').clearHighLight(className);
					}
					else if(hlword.length > 0){
						var count = 0;
						
						count += $(".highlightText:visible").executeHighLight(hlword, className);
						$(this).val(hlword + '(\u200B' + count + ')');
						$('input[name=highlighters]').eq(i).val(hlword);
					}else{
						$(this).val("");
						$('input[name=highlighters]').eq(i).val("");
					}
				}
			});
		};
		
		
