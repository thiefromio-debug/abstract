	function getJsonDataHighlight(inputStr, hlword, className){
		var tmpDiv = "<div>" + (inputStr == null ? "" : inputStr) + "</div>";
		if(className != "font_color_orange"){
			//검색어 하이라이트인 경우에는 초기화 하지 않는다.
			tmpDiv = "<div>" + $(tmpDiv).clearHighLightByElement(className) + "</div>";
		}
		
		var outRsltVO = $(tmpDiv).highLight(hlword, className);
		if(outRsltVO.html == 'undefined' || outRsltVO.html == null){
			outRsltVO.html = '';
			outRsltVO.cnt = 0;
		}
		return outRsltVO;
	};
	
