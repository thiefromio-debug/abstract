		/**
		 * 현재진행상태 오픈 JP 처리
		 */
		scope.openStatusJP = function(mngNum, docKind, publNum, reJtpIntrPublNum, rghtSect, mngKind, grtNum, firmNum, firmDt, issDt){
			var strKA = "";
			var patNum = mngNum == null ? "" : $.trim(mngNum);
			var patKind =  mngKind == null || $.trim(mngKind) == '' ? 0 : ($.trim(mngKind));
			var patUrl = "";
			docKind == null ? "" : $.trim(docKind.toUpperCase());
			publNum == null ? "" : $.trim(publNum);
			reJtpIntrPublNum == null ? "" : $.trim(reJtpIntrPublNum);
			rghtSect == null ? "" : $.trim(rghtSect);
			grtNum == null ? "" : $.trim(grtNum);
			firmNum == null ? "" : $.trim(firmNum);
			firmDt == null || $.trim(firmDt) == '' ? "0" : $.trim(firmDt);
			issDt == null || $.trim(issDt) == '' ? "0" : $.trim(issDt);
			
			// doc_kind가 공개/공표가 아니거나 공개번호의 일련번호 첫자리가 5가 아닐 경우에만 실행한다.
	        if ((docKind != "A") || (publNum.substr(5, 1) != "5"))
	        {
	        	// 문헌 종류가 특허이고, 국제발행일자가 없을 경우에는 특허이고, 문헌종류가 실용이면 그냥 실용
	        	if (reJtpIntrPublNum == "" && rghtSect == "P"){
	        		strKA = "P";
	        	} else if (rghtSect == "U") {
	        		strKA = "U";
	        	}

	        	// 특허번호를 설정한다.
	        	// WIPS 4.0 과 doc_kind 비교
	        	// XC	  DOC_KIND
	        	// 1	  1
	        	// 2	  4
	        	// 3	  8
	        	// 4	  9
	        	// 5	  5
	        	// 6	  2, 3
	        	// 7	  6, 7
	        	if (patKind == 1 || patKind == 4 || patKind == 8 || patKind == 9){
	        		// 공표 및 국제공개번호는 공개번호가 존재하지 않으므로 기존번호 그대로 유지
	        		if (publNum != null){
	                  patNum = publNum;
	                }
	        	} else if ((patKind == 6 || patKind == 7) && grtNum == "") {
	        		patNum = firmNum;
	        	} else if (patKind == 2 || patKind == 3) {
	                if (firmNum != "" && firmDt < 19960401){
	                	patNum = firmNum;
	                } else if (grtNum != "" && issDt >= 19960401){
	                	patNum = grtNum;
	                }
	        	} else {
	        		patNum = grtNum;
	        	}

	        	// 날짜를 일왕년도로 바꾼다.
	        	var strConv_JPYear = "";
	        	var strYear;
	        	var strNum;
	        	var iTempNum = 0;
	        	if (patKind == 1 || patKind == 4) {
	        		strYear = patNum.substr(0, 4) * 1;
	        		strNum = patNum.substr(5, 6) * 1;
	        		if (strYear >= 1926 && strYear < 1989) {
	        			iTempNum = strYear - 1925;
	        			if (iTempNum < 10) {
	        				strConv_JPYear = "0" + iTempNum;
	        			} else {
	        				strConv_JPYear = iTempNum + "";
	        			}
	        			strConv_JPYear = "S" + strConv_JPYear;
	        		} else {
	        			iTempNum = strYear - 1988;
	        			if (iTempNum < 10) {
	        				strConv_JPYear = "0" + iTempNum;
	        			} else {
	        				strConv_JPYear = iTempNum + "";
	        			}
	        			strConv_JPYear = "H" + strConv_JPYear;
	        		}
	        		patNum = strConv_JPYear + "-" + strNum;
	        	}
	        }
	        
