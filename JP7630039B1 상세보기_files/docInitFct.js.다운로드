				var thisCheck = $(this);
				if ( thisCheck.is(':checked') ) {
					$( "li[id^='li_']:not([id$='first'])" ).hide();
					$( "li[id^='li_'][id$='first']" ).addClass("close"); 
					$( "button[id^='bt_']" ).removeClass("toggle2 minus").addClass("toggle2 plus");
				}else{
					$( "li[id^='li_']:not([id$='first'])" ).show();
					$( "li[id^='li_'][id$='first']" ).removeClass("close");
					$( "button[id^='bt_']" ).removeClass("toggle2 plus").addClass("toggle2 minus");
				}
			});
		};
		
