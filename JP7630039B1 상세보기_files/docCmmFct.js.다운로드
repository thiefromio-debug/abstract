	function openClsLayer(scope, clsType , clsStatus  , clsIndex , clsMode , clsCd) {
		clsCd = clsCd.replace(/(^\s*)|(\s*$)/gi, "");
		
		if(clsType == 'ipc' && clsCd.length == 8){//ipc 일 경우 /00 처리
			clsCd += '/00';
		}
		
		if(clsType == 'upc' && clsCd.indexOf('.') > -1 ){//upc 일 경우 ITS-8665 처리
			if(clsCd.split('.')[1].length == 1) {
				clsCd += '00';
			} else if(clsCd.split('.')[1].length == 2) {
				clsCd += '0';
			}
		}
		
		if ($('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).css("display") == "none") {
			var divId = clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode;
	    	var lyrId = clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode;
			scope.layerHide();
			$('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).show();
			$('#'+clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode).attr("style", "position:relative;");
			
			var cnt = $('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode+' > div').length;
			if(cnt == 0){
				scope.lyrClsHierarchy(clsType , clsStatus  , clsIndex , clsMode , clsCd.replace("\:" , "\/"));	
			}
			
		}else{
			scope.closeClsLayer(clsType , clsStatus  , clsIndex , clsMode) ;
		}
	};
	
	function openClsLayerFi(scope, clsType , clsStatus  , clsIndex , clsMode , clsCd, unfdSymb, savRecgSymb) {
		clsCd = clsCd.replace(/(^\s*)|(\s*$)/gi, "");
		var inputFiCls = clsCd;
		
		if(unfdSymb != null ) {
			unfdSymb = unfdSymb.replace(/(^\s*)|(\s*$)/gi, "");
			inputFiCls += ',';
			inputFiCls += unfdSymb;
		} 
		
		if(savRecgSymb != null ) {
			savRecgSymb = savRecgSymb.replace(/(^\s*)|(\s*$)/gi, "");
			inputFiCls += '@';
			inputFiCls += savRecgSymb;
		} 
		
		if ($('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).css("display") == "none") {
			var divId = clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode;
	    	var lyrId = clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode;
			scope.layerHide();
			$('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).show();
			$('#'+clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode).attr("style", "position:relative;");
			
			var cnt = $('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode+' > div').length;
			if(cnt == 0){
				scope.lyrClsHierarchy(clsType , clsStatus  , clsIndex , clsMode , inputFiCls.replace("\:" , "\/"));	
			}
		}else{
			scope.closeClsLayer(clsType , clsStatus  , clsIndex , clsMode) ;
		}
	};
	
	function layerHide() {
		var clsKinds = ["cpc", "ipc", "upc", "fi" , "fterm","locarno"];
		for (var i = 0; i < clsKinds.length; i++) {
			$( "div[id^="+clsKinds[i]+"_curr_lyr_]").hide();
			$( "div[id^="+clsKinds[i]+"_curr_div_]").attr("style", "");
			
			$( "div[id^="+clsKinds[i]+"_orig_lyr_]").hide();
			$( "div[id^="+clsKinds[i]+"_orig_div_]").attr("style", "");
			
			//wips 패밀리 IPC/CPC
			$( "div[id^="+clsKinds[i]+"_main_lyr_]").hide();
			$( "div[id^="+clsKinds[i]+"_main_div_]").attr("style", "");
		}
	};
	
	function closeClsLayer(clsType , clsStatus  , clsIndex , clsMode) {
		$('#'+clsType+'_'+clsStatus+'_lyr_'+clsIndex+'_'+clsMode).hide();
		$('#'+clsType+'_'+clsStatus+'_div_'+clsIndex+'_'+clsMode).attr("style", "");
	};
	
	function lyrClsHierarchy(scope, clsType , clsStatus  , clsIndex , clsMode , clsCd) {
