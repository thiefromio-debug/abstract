/**
 * 고객센터 검색결과 > 이용매뉴얼 하이라이트
 */
function ctsUserManualHighLighter(hlKeyword){
	if(hlKeyword != '' && hlKeyword != null ){
		var keywordArray = hlKeyword.split(' ');
		for (var i = 0; i < keywordArray.length; i++) {
			if(keywordArray[i] != null && keywordArray[i] != ""){
				$("div.helpcenter_menual_block").executeHighLight(keywordArray[i], 'font_bgc_yellow no_arrow');
			}
		}	
	}
}

