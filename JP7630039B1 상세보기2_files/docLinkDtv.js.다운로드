docApp.directive('docLinkFamilyDtv', ['$timeout','$http','$compile','docCmmFct', function($timeout, $http, $compile, docCmmFct){
	return {
		restrict: 'A',
		link : 	postLink  //compile 이 등록되어 있으면 link 는 수행하지 않는다.
	};
	
	function postLink(scope, elm, attrs, ctrl){
		scope.$watch(attrs.ngModel, function(ctry){
			var type = "",
				url  = "",
				mngKind = scope.docVar.screenVO.mngKind;
			
			if(ctry != "EP" && ctry != "WO"){
				if(mngKind == "1" || mngKind == "4" || mngKind == "8" || mngKind == "9"){
					type = "PN";
				} else {
					type = "RN"
				}
			} else{
				type = "PN"
			}
			
			url = "javascript:registerFamilySdi('" + ctry + "','" + type + "','" + scope.docVar.screenVO.mngNum + "');";
			elm.attr("href", url);
			//elm.attr("target", "_blank");
		});
		
	};
}]);