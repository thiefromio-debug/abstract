docApp.directive('docPdfFunctionDtv', ['$timeout','$http','$compile','docCmmFct', function($timeout, $http, $compile, docCmmFct){
	return {
		restrict: 'A',
		link : 	postLink  //compile 이 등록되어 있으면 link 는 수행하지 않는다.
	};
	
	function postLink(scope, elm, attrs, ctrl){
		scope.$watch(attrs.ngModel, function(value){
			var pdfSkey = value.skey;
			var pdfCtry = value.ctry;
			
			if(pdfSkey == null || pdfSkey == '' ){
				elm.attr("href", "javascript:alert('입력 받은 키가 존재하지 않습니다.');");    
			} else if($(elm).hasClass("btn_dispdf")){
				$(elm).attr("disabled", true);
			} else {
				var url = "javascript:pdfOpen('" + pdfSkey + "','" + pdfCtry + "');";
				elm.attr("href", url);    
			}
		});
	};
}]);

