docApp.directive('docLinkDtv', ['$timeout','$http','$compile','docCmmFct', function($timeout, $http, $compile, docCmmFct){
	return {
		restrict: 'A',
		link : 	postLink  //compile 이 등록되어 있으면 link 는 수행하지 않는다.
	};
	
	function postLink(scope, elm, attrs, ctrl){
		scope.$watch(attrs.ngModel, function(value){
			if(value.skey == null || value.skey == '' ){
				elm.attr("href", "javascript:alert('입력 받은 키가 존재하지 않습니다.');");    
			} else {
				var url = docCmmFct.getDocUrl(value.ctry, value.skey) + "?skey=" + value.skey; //DocConst.DOC_URL: '../doc/docView.wips'
				elm.attr("href", url);
				elm.prop("target", "_blank");
			}
			
		});
	};
}]);


