							           <col width="150" />
							           <col width="130" />
							           <col width="*" />
							          </colgroup>
							          <thead>
							          	 <tr>
							               <th class="tb_head_backcolor">No</th>
							               <th class="tb_head_backcolor">원문</th>
							               <th class="tb_head_backcolor"><a href="javascript:void(0);" ng-click="prBackPatListSort(3)" ng-class="docVar.docPrBackPatVO.headerList[3].fontClass"><span ng-bind-html="docVar.docPrBackPatVO.headerList[3].fieldNm"></span><span ng-class="docVar.docPrBackPatVO.headerList[3].arrClass"><!-- --></span></a></th>
							               <th class="tb_head_backcolor"><a href="javascript:void(0);" ng-click="prBackPatListSort(4)" ng-class="docVar.docPrBackPatVO.headerList[4].fontClass"><span ng-bind-html="docVar.docPrBackPatVO.headerList[4].fieldNm"></span><span ng-class="docVar.docPrBackPatVO.headerList[4].arrClass"><!-- --></span></a></th>
							               <th class="tb_head_backcolor font_align_left">발명의 명칭</th>
							             </tr>
							          </thead>
