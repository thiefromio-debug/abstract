	                        </div>
	                        <div class="dc_context_block">
							   <div class="float_l">
							      <span class="float_l marg_right_20">전체 <span class="font_type_bold page_backcolor_step1_text font_valign_00" ng-bind="docVar.docPrBackPatVO.pageCountVO.totRsltCnt"></span> 건</span>
