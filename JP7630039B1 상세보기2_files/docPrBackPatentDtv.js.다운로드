							               <td>
							               		<a ng-hide="prPat.skey == null || prPat.skey == ''" doc-link-dtv ng-model="prPat"><span ng-bind-html="prPat.applNum"></span></a>
							               		<span ng-show="prPat.skey == null || prPat.skey == ''" ng-bind-html="prPat.applNum"></span>
