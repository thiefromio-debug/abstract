docApp.directive('docPrBackPatentDtv', ['$timeout','$http','$compile','docCmmUtilFct', 'docCmmFct', 'docCmmLinkFct', function($timeout, $http, $compile, docCmmUtilFct, docCmmFct, docCmmLinkFct){
	return {
		restrict: 'A',
		link : 	postLink  //compile 이 등록되어 있으면 link 는 수행하지 않는다.
	};
	
	function preCompile(scope, elm, attrs, ctrl){
		/**
		 * 변수 초기화
		 */
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.skey = scope.docVar.screenVO.skey;
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplFlag = 0; // 0: 중복제거, 1 : 중복허용
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortField = "pat_dt";
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortType = "DESC";
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum = 1;
		scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageRow = DocCmmConst.PR_PAT_PAGE_ROW;
		scope.docVar.docPrBackPatVO.headerList = [
		                       		       {id:'chk', fieldNm:'', sortField:'', sortType:'', arrClass:''}   //check
		                       		     , {id:'ORG', fieldNm:'원문', sortField:'', sortType:'', arrClass:''}   //원문
		                       		     , {id:'CC', fieldNm:'국가', sortField:'ctry', sortType:'', arrClass:''}   //국가
		                       		     , {id:'AN', fieldNm:'문헌번호', sortField:'pat_num', sortType:'DESC', arrClass:'ico_arralign ico_default', thClass:'tb_head_backcolor'}   //문서번호
		                       		     , {id:'AD', fieldNm:'일자', sortField:'pat_dt', sortType:'DESC', arrClass:'ico_arralign ico_default', thClass:'tb_head_backcolor'}   //일자
		                       		     , {id:'TI', fieldNm:'발명의 명칭', sortField:'', sortType:'', arrClass:''}   //발명의 명칭
		                       		];
		
		
		// 전체 카운트
		scope.docVar.docPrBackPatVO.pageCountVO.totRsltCnt = 0;
		// 전체 페이지수 
		scope.docVar.docPrBackPatVO.pageCountVO.totPageCnt = 1;
		// 보유 건수
		scope.docVar.docPrBackPatVO.pageCountVO.holdCnt = 0;
		// 미보유 건수 
		scope.docVar.docPrBackPatVO.pageCountVO.missingDocCount = 0;
		// provisional 건수 
		scope.docVar.docPrBackPatVO.pageCountVO.provisionalCount = 0;
		
		scope.findPrBackPatList = function() {
			// 변수 docCmmVar 및 docCmmConst 로 빼기.
			var url = "../doc/findDocPrBackPat.wips";
			var obj = { skey : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.skey
						, sortField : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortField
						, sortType : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortType
						, pageNum : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum
						, pageRow : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageRow
						, duplFlag : scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplFlag
					  };

			$http.post(url, $.param(obj),{
				headers: {'Content-Type': scope.docConst.JSON_CONT_TYPE}
			}).success(function(data){
				
				scope.docVar.docPrBackPatVO.skeys = data.skeys;

				scope.docVar.docPrBackPatVO.allChk = false;
				// 보유목록
				scope.docVar.docPrBackPatVO.rsltList = data.prPatBackRsltVOList;
				
				//checkbox 초기화
				if(scope.docVar.docPrBackPatVO.rsltList.length > 0) {
					for(var i=0; i < scope.docVar.docPrBackPatVO.rsltList.length; i++){
						scope.docVar.docPrBackPatVO.rsltList[i].chk = false;
					}
				}
				
				// Provisional of 목록
				scope.docVar.docPrBackPatVO.provisionalList = data.provisionalList;
				// 미보유 목록
				scope.docVar.docPrBackPatVO.missingList = data.missingList;
				// 전체 건수 = 보유문헌 건수 + 미보유 건수 + provisional 건수 
				scope.docVar.docPrBackPatVO.pageCountVO.totRsltCnt = data.prPatBackCnt.totalCnt + data.prPatBackCnt.missingDocCount + data.prPatBackCnt.provisionalCount;
				// 전체 페이지
				if(data.prPatBackCnt.totalPage != 0) {
					scope.docVar.docPrBackPatVO.pageCountVO.totPageCnt = data.prPatBackCnt.totalPage;
				}
				// 미보유 건수
				scope.docVar.docPrBackPatVO.pageCountVO.missingDocCount = data.prPatBackCnt.missingDocCount;
				
				scope.docVar.docPrBackPatVO.pageCountVO.pageNum = scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum;
				scope.docVar.docPrBackPatVO.pageCountVO.pageRow = scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageRow;
				scope.clickDevBtnMarker();
			}).error(function(data, status){
				/*if (/EgovBizException/.test(data.responseText)) {
		            alert(data.responseText.match(/EgovBizException: &quot;(.*?)&quot;/)[1]);
		            // error 처리
		        }
		        else {
		            alert("에러가 발생하였습니다. " + status + "\nError: " + data.responseText);
		        }*/
			});
			
		};
		
		/**
		 * 헤더에서 소트키 클릭시
		 */
		scope.prBackPatListSort = function(headerIndex){
			
			for(var i = 0; i < scope.docVar.docPrBackPatVO.headerList.length; i++){
				if(scope.docVar.docPrBackPatVO.headerList[i].sortField === ''){
					continue;
				}
				
				if(i === headerIndex) {
					if(scope.docVar.docPrBackPatVO.headerList[i].sortType === "DESC") {
						scope.docVar.docPrBackPatVO.headerList[i].sortType = "ASC";
						scope.docVar.docPrBackPatVO.headerList[i].arrClass = "ico_arralign ico_arrup";
						//scope.docVar.docPrBackPatVO.headerList[i].thClass = "tb_head_backcolor font_color_orange";
						scope.docVar.docPrBackPatVO.headerList[i].fontClass = "font_color_orange";
					} else {
						scope.docVar.docPrBackPatVO.headerList[i].sortType = "DESC";
						scope.docVar.docPrBackPatVO.headerList[i].arrClass = "ico_arralign ico_arrdown";
						//scope.docVar.docPrBackPatVO.headerList[i].thClass = "tb_head_backcolor font_color_orange";
						scope.docVar.docPrBackPatVO.headerList[i].fontClass = "font_color_orange";
					}
					scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortField = scope.docVar.docPrBackPatVO.headerList[i].sortField;
					scope.docVar.docPrBackPatVO.docPrBackPatParamVO.sortType = scope.docVar.docPrBackPatVO.headerList[i].sortType;
				} else {
					scope.docVar.docPrBackPatVO.headerList[i].arrClass = "ico_arralign ico_default";
					//scope.docVar.docPrBackPatVO.headerList[i].thClass = "tb_head_backcolor";
					//scope.docVar.docPrBackPatVO.headerList[i].fontClass = "font_color_orange";
				}
			}
			
			scope.findPrBackPatList();
		};
		
		/**
		 * 이전페이지 클릭시
		 */
		scope.prevPagePrBack = function(){
			if(scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum == 1){
				return;
			}
			
			scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum = scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum - 1;
			scope.findPrBackPatList();
		};
		
		/**
		 * 다음페이지 클릭시
		 */
		scope.nextPagePrBack = function(){
			if(scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum == scope.docVar.docPrBackPatVO.pageCountVO.totPageCnt){
				return;
			}
			
			scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum = scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum + 1;
			scope.findPrBackPatList();
		};
		
		//원문 아이콘 class
		scope.pdfIconClass = function(pdfGb, ctry) {
			if(ctry == "CA"){
				pdfGb = 0;
			}
			
			if(pdfGb == 1 || pdfGb == 2) {
				return 'btn_openpdf';
			}
			else { // null
				return "btn_dispdf";
			}
		};

		/**
		 * 중복체크 클릭
		 */
		scope.prBackDupChk = function(){
			if(scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplChk) {
				scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplFlag = 0;
			}else {
				scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplFlag = 1;
			}
			scope.docVar.docPrBackPatVO.docPrBackPatParamVO.pageNum = 1;

			scope.findPrBackPatList();
		};

		/**
		 * 중복체크 라벨 클릭
		 */
		scope.prBackDupChkClick = function(){
			scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplChk = !scope.docVar.docPrBackPatVO.docPrBackPatParamVO.duplChk;
			scope.prBackDupChk();
		};
	};
	
	
	
