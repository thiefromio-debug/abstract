							            </a>
							            <span ng-if="docVar.docPrBackPatVO.pageCountVO.pageNum <= 1"> 
							            	<span class="direction btn_dis_type">
							            		<span class="prev"><!-- --></span>
							            		<span class="ir_pm">이전</span>
							            	</span>
							            </span>
							            <a ng-if="docVar.docPrBackPatVO.pageCountVO.totPageCnt > docVar.docPrBackPatVO.pageCountVO.pageNum" href="javascript:void(0);" ng-click="nextPagePrBack();">
