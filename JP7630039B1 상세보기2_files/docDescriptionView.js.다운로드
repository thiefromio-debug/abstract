;(function($){
	$.makeHalfDescription = function(textDescription){
		leftDtlDesc = "";
		rightDtlDesc = "";
		if(textDescription == null){
			textDescription = "";
		}
		
		var halfLength = textDescription.replace(/<img (.+?)>/ig,"").length / 2; // 기준 길이
		var textLength = 0; // 누적 길이
		var htmlArray = $.parseHTML(textDescription);
		
		if(htmlArray.length < 2) {
			leftDtlDesc += textDescription;
		} else {
		
			for (var i = 0; i < htmlArray.length; i++) {
				textLength += htmlArray[i].textContent.length;
				if(textLength < halfLength) {// 좌측 : 누적된 text 길이가 총 길이의 반(기준)보다 작을 경우
					if(htmlArray[i].outerHTML != undefined) {
						leftDtlDesc += htmlArray[i].outerHTML;  
					} else {
						if(htmlArray[i].nodeName == "#comment") {
							//leftDtlDesc += htmlArray[i];
						} else {
							leftDtlDesc += htmlArray[i].textContent;
						}
					}
				} else {// 우측
					if(htmlArray[i].outerHTML != undefined) {
						rightDtlDesc += htmlArray[i].outerHTML;  
					} else {
						if(htmlArray[i].nodeName == "#comment") {
							//
						} else {
							rightDtlDesc += htmlArray[i].textContent;
						}
					}
				}
			}
		
		}
	};
	
	
	//NMT 번역
	$.ajaxGetNMTData = function(item, langCd){
		
		if(getNmtDataYn == false){
			$.openLoadingBar();
			
			$.ajax({
				url: "../doc/selectTrnsNMT.wips",
				type: "post",
			    cache: false,
			    async: true,
			    dataType: 'json',
				data: {
					skey: $('#skey').val()
					,item : item
					,langCd : langCd
					,ctry : $("#ctry").val()
					,entryWay : "DOC"
				},
				success: function(data, textStatus, jqXHR) {
					descTrnsList.push(data.nmtVO);
					dataDSView();
					$("#devNmtBlock").hide();
					$.closeLoadingBar();
					getNmtDataYn = true;
				},
				error: function (xhr, textStatus, errorThrown) {
					$.closeLoadingBar();
				}
			});
		} else {
			dataDSView();
		}
	}
})(jQuery);

