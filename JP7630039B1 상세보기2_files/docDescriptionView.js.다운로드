function quotedRegx(keyword) {
	keyword = keyword == undefined ? '' : keyword;
	var regexpSpecialChars = /([\[\]\^\$\|\(\)\\\+\*\?\{\}\!\.])/gi;
	var quotedKeyword = keyword.replace(regexpSpecialChars, '\\$1');

	return quotedKeyword;
}

function sortNameDesc(obj) {
	var cidArr = Object.keys(obj);
	var mapped = cidArr.map(function(cid, i) {
		return {index: i, value: obj[cid]};
	});
	
	mapped.sort(function(a, b) {
		return +(a.value < b.value) || +(a.value === b.value) - 1;
	});
	
	return mapped.map(function(el) {
		return cidArr[el.index];
	});
}

function markerHighLighterDocWithChemicalName(cidObj) {
	
	//이름의 역순으로 정렬 (최장일치로 하이라이트 처리하기 위함)
	var sortedArr = sortNameDesc(cidObj);
	
	var className = 'highlight_text_chem highlight_draw_text';
	
	$("div.highlightText, span.highlightText").each(function() {
		var replaced = $(this).html();
		
		sortedArr.forEach(function(cid) {
			var cnameArr = cidObj[cid];
			cnameArr.forEach(function(cname) {
				var keyword = cname.replace(/(^\s*)|(\s*$)/gi, '');
				
				if(keyword.lastIndexOf('(\u200B') > -1){
					keyword = keyword.substring(0, keyword.lastIndexOf('(\u200B'));
				}
				var keyReg = new RegExp('(\\s|\\(|\>)(' + quotedRegx(keyword) + ')(\\s|\\.|\\,|\\)|\<)', 'ig');
				replaced = replaced.replace(keyReg, '$1<span class="' + className + '" cid="' + cid + '" >$2</span>$3');
			});
		});
		
		$(this).html(replaced);
	});
	
	highlightDraw();
}


var highlightDraw = function(){
	$('.highlight_draw_text').hover(function() {// 마우스 오버 했을 때
		
		var cid = $(this).attr('cid');
		
		var IMAGE_HEIGHT = 242;
		
		var highlightText_top = $(this).outerHeight() + $(this).offset().top;
		var highlightText_left = $(this).offset().left;
		
		if (highlightText_top - $(window).scrollTop() + IMAGE_HEIGHT > $(window).height()) {
			highlightText_top = $(this).offset().top - IMAGE_HEIGHT; 
		}
		
		if ($('#devCidImage' + cid).length === 0) {
			makeImageDiv(cid);
		}
		
		$('#devCidDiv' + cid).show();
		$('#devCidDiv' + cid).css({'top':highlightText_top+"px",'left':highlightText_left+"px"});
	}, function() {// 마우스 아웃 했을 때
		
		$('.highlight_draw_img').hide();
	});
};

