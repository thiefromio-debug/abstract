function DSDataContentsLangCd(trns, list, langCd){
	var tmpList = "";
	
	//대체정보
	var replTag = "";
	var trnsView = trns == 1 ? 2 : 0;
	var ctry = $("#ctry").val();
	if(langCd != ''){
		$.each(list, function(idx, val){
			if(langCd == val.langCd.toLowerCase()){
				tmpList = val.dtlDesc;
				if(val.docKind != null && val.docKind != ''){
					replTag = "<div class='title_trans'>↓" + val.ctry +" " + val.docNum + " " + val.docKind + " 문헌의 발명의 설명</div><br/>";
				}
				if(trns == 1){
					if(ctry == "WO"){
						trnsView = val.trns;
					}
				}
			}
		});
	}
	else{
		if(list != null && list.length > 0){
			tmpList = list[0].dtlDesc;
			if(list[0].docKind != null && list[0].docKind != ''){
				replTag = "<div class='title_trans'>↓" + list[0].ctry +" " + list[0].docNum + " " + list[0].docKind + " 문헌의 발명의 설명</div><br/>";
			}
			if(trns == 1){
				if(ctry == "WO"){
					trnsView = list[0].trns;
				}
			}
		}
	}
	
	if((tmpList != null && trns == 1)){
		tmpList = (trnsView == 2 ? "<p class='title_trans'>기계번역</p><div class='clear'><!--  --></div>" : "") 
					+ (replTag != "" ? replTag : "")
					+ tmpList;
	}
	
	return tmpList;
}

