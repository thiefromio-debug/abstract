	        if (c == '0') {
	            strReturn = strInput.substring(i, strInput.length - i);
	        } else {
	            strReturn = strInput.substring(i, strInput.length - i);
	            break;
	        }
	    }
	    
	    return strReturn;
	};
	
	var filterText = function(jdgNotcNum) {
