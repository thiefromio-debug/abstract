/**
 * 공개번호 , 등록 / 공고번호 한글 타이틀 명치 필터
 */
;
docApp.filter("numTitleKorFilter", function() {
	var filterText = function(mngKind, docType) {
		var rtnValue = "";
		
		if(docType === 'KR') {
			
			if(mngKind === "1" || mngKind == "4"){
				rtnValue = "공개번호";
			} else {
				rtnValue = "등록/공고번호";
			}
		} else if(docType === 'US') {
			
			if(mngKind === "1"){
				rtnValue = "공개번호";
			} else {
				rtnValue = "등록번호";
			}
		} else if (docType === 'JP') {
			
			if(mngKind === "1" || mngKind == "4"){
				rtnValue = "공개번호";
			} else if(mngKind === "8"){
				rtnValue = "공표번호";
			} else if(mngKind === "9"){
				rtnValue = "국제공개번호";
			} else {
				rtnValue = "특허번호";
			}
		} else if (docType === 'CN') {
			
			if(mngKind === "1" || mngKind == "4"){
				rtnValue = "공개번호";
			} else {
				rtnValue = "등록번호";
			}
		} else if (docType === 'WO') {
			rtnValue = "공개번호";
		} else if (docType === 'DB') {
			rtnValue = "특허번호";
		} else if (docType === 'PAJ'){
			rtnValue = "공개번호";
		} else {
			// 기타 개별국 docType 가 다양하다 DE, FR, 등등
			rtnValue = "특허번호";
		}
		
		return rtnValue;
	};
	return filterText;
});

/**
 * 해당 헹리먼트안의 문자중 하이라이트 변경 처리를 한다.
 */
docApp.filter("highLightFilter", function() {
	var filterText = function(inputStr, highLightStr) {
		var outStr = inputStr;
		if(outStr != undefined) {
			outStr = outStr.replace(highLightStr, "<span class='font_color_orange'>" + highLightStr + "</span>");
		}
		
		return outStr;
	};
	return filterText;
});


/**
 * 법적상태 PrsCd Filter 처리
 */
docApp.filter("legalStatusPrsCdFilter", function() {
	var filterText = function(prsCd, symb) {
		var rtnValue = ''; //prsCd;
		if(symb === "+") {
			//rtnValue += "<font color='green'>";
			rtnValue += "<span class='font_color_green font_type_bold'>";
		}else if(symb === "-") {
			//rtnValue += "<font color='red'>";
			rtnValue += "<span class='font_color_red font_type_bold'>";
		}else {
			rtnValue += "<span class='font_color_black font_type_bold'>";
		}
		
		rtnValue += prsCd;
		
		if(symb === "+") {
			rtnValue += "</span>";
		}else if(symb === "-") {
			rtnValue += "</span>";
		}else {
			rtnValue += "</span>";
		}
		
		return rtnValue;
	};
	return filterText;
});

/**
 * 법적상태 Desc Filter 처리
 */
docApp.filter("legalStatusDescFilter", function() {
	var filterText = function(desc, remark) {
		var rtnValue = ''; //
		var remarkArray = remark != null ? remark.split('|') : [];
		var rmarkSplitArray;
		
		rtnValue += desc;
		for(var i=0; i < remarkArray.length; i++){
			rmarkSplitArray = remarkArray[i].split(':');
			if(rmarkSplitArray !== null && rmarkSplitArray.length > 0) {
				rtnValue += "<br/><span class='font_type_bold'>" + rmarkSplitArray[0] + "</span>";
				
				for(var j=1; j < rmarkSplitArray.length; j++) {
					rtnValue += " : " + rmarkSplitArray[j];
				}
			}
		}
		
		
		return rtnValue.replace(/&amp;/gi,'&');
	};
	return filterText;
});
