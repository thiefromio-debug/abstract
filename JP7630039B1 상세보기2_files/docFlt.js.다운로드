			rtnHtml += " (" + jdgNotcNum + ")";
		}
		
		return rtnHtml;
	};
	
	return filterText;
});


docApp.filter('trustAsHTML', ['$sce', function($sce){
	return function(text) {
		return $sce.trustAsHtml(text);
	};
}]);

docApp.filter("addStrFilter", function() {
	var filterText = function(input, addStr, addType) {
		input = $.trim(input);
		
		if(input != null && input != ""){
			if(addType === "pre"){
				return (addStr == null ? "" : addStr) + input;
			} else if (addType === "next"){
				return input + (addStr == null ? "" : addStr);
			}
		} else if(input == null){
			return "";
		} else {
			return input;
		}
	};
	return filterText;
});

docApp.filter("nonDataFlt", function() {
	var filterText = function(input, type) {
		input = $.trim(input);
		if(type==="title"){
			if(input != null && input != ""){
				return input
			} else {
				return 'No Title';
			}
		}
	};
	return filterText;
});