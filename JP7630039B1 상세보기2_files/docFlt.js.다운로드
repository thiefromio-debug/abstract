docApp.filter('dateFilter', function() {
	var filterText = function(input) {
		if(input != null && input.length === 8){
			var txt1 = input.substr(0, 4),
				txt2 = input.substr(4, 2),
				txt3 = input.substr(6, 2);
			
			return txt1 + '.' + txt2 + '.' + txt3;
		} else if(input == null){
			return "";
		} else {
			return input;
		}
	};
	return filterText;
});
/**
 * Data Null Check Filter
 */
docApp.filter("dataNullFilter", function() {
	var filterText = function(input, addStr) {
		input = $.trim(input);
		//console.log(input);
		if(input == null || input == ""){
			return input = "-";
		} else {
			return input;
		}
	};
	return filterText;
});
