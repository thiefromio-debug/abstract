	function drawContents(scope, elm, value, clTrnsCnt, descTrnsCnt, clType, isTrns, mngNum, docKind, mngDt){
		switch (value){
		case scope.docConst.TABGB.CL:
			switch (scope.docVar.screenVO.serviceNm){
			case scope.docConst.SERVICENM.DKR:
				krClDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DCN:
				cnClDrawContents(scope, elm, clTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DEP:
				epClDrawContents(scope, elm, clTrnsCnt, clType);
				break;
			case scope.docConst.SERVICENM.DJP:
				jpClDrawContents(scope, elm, clTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DLN:
				lnClDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DUS:
				usClDrawContents(scope, elm, clTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DUT:
				utClDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DWO:
				woClDrawContents(scope, elm);
				break;
			default:
				defDrawContents(scope, elm);
				break;
			}
			break;
		case scope.docConst.TABGB.DS:
			switch (scope.docVar.screenVO.serviceNm){
			case scope.docConst.SERVICENM.DKR:
				krDsDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DCN:
				cnDsDrawContents(scope, elm, descTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DEP:
				epDsDrawContents(scope, elm, descTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DJP:
				jpDsDrawContents(scope, elm, descTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DLN:
				lnDsDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DUS:
				usDsDrawContents(scope, elm, descTrnsCnt);
				break;
			case scope.docConst.SERVICENM.DUT:
				utDsDrawContents(scope, elm);
				break;
			case scope.docConst.SERVICENM.DWO:
				woDsDrawContents(scope, elm, descTrnsCnt);
				break;
			default:
				defDrawContents(scope, elm);
				break;
			}
			break;
		case scope.docConst.TABGB.AB:
			elm.empty();
			elm.hide();
			break;
		case scope.docConst.TABGB.AD:
			switch (scope.docVar.screenVO.serviceNm){
			case scope.docConst.SERVICENM.DKR:
			case scope.docConst.SERVICENM.DEP:
			case scope.docConst.SERVICENM.DUS:
				elm.empty();
				elm.hide();
				break;
			default:
				defDrawContents(scope, elm);
				break;
			}
			break;
		case scope.docConst.TABGB.FT:
			switch (scope.docVar.screenVO.serviceNm){
			case scope.docConst.SERVICENM.DJT:
				jtFtDrawContents(scope, elm, isTrns, mngNum, docKind, mngDt);
				break;
			}
			break;
		default:
			defDrawContents(scope, elm);
			break;
		}
	};
	
